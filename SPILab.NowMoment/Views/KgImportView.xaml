<!-- ════════════════════════════════════════════════════════════════════
     Views/KgImportView.xaml — JSON/TTL 임포트 화면 (SCR-B03)

     구조:
       Row 0: 헤더 + 안내문
       Row 1: 카드 1 (대상 도메인 선택 + 현재 상태 미리보기)
       Row 2: 카드 2 (파일 선택 + 파일 정보)
       Row 3: 카드 3 (커밋 버튼 + 결과 메시지)
       Row 4: 보조 액션 (출력 폴더 열기 / 도메인 비우기)

     모든 동작은 KgImportViewModel 이 v3 KnowledgeGraphService.ImportFromFile
     을 직접 호출하여 SQLite 트랜잭션으로 임포트.
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.KgImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="맑은 고딕">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,16" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ Row 0: 헤더 ════════ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="📥 JSON / TTL 임포트"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource Theme.Accent}"/>
                <TextBlock Text="빌더 산출물(JSON·TTL)을 SQLite 트랜잭션으로 안전하게 임포트합니다."
                           Foreground="{DynamicResource Theme.FgMuted}"
                           FontSize="12" Margin="0,4,0,0"/>
                <TextBlock Text="기존 노드/엣지는 도메인 단위로 갱신됩니다. 임포트 전 [도메인 비우기] 로 초기화할 수 있습니다."
                           Foreground="{DynamicResource Theme.FgMuted}"
                           FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ════════ Row 1: 도메인 선택 카드 ════════ -->
            <Border Grid.Row="1" Style="{StaticResource DetailCard}" Padding="18,14" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                            Padding="10,0,0,0" Margin="0,0,0,12">
                        <TextBlock Text="1. 대상 도메인 선택"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgPrimary}"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="도메인"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Domains}"
                                  SelectedItem="{Binding SelectedDomain, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="2" Content="🔄 새로고침"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshPreviewCommand}"
                                Margin="8,0,0,0"
                                ToolTip="현재 도메인 통계 다시 계산"/>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource Theme.BgGridRowOdd}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8">
                        <TextBlock Text="{Binding PreviewLabel}"
                                   Foreground="{DynamicResource Theme.FgPrimary}"
                                   FontSize="12" FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════ Row 2: 파일 선택 카드 ════════ -->
            <Border Grid.Row="2" Style="{StaticResource DetailCard}" Padding="18,14" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                            Padding="10,0,0,0" Margin="0,0,0,12">
                        <TextBlock Text="2. 임포트할 파일 선택"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgPrimary}"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="파일"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Background="{DynamicResource Theme.BgCard}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                CornerRadius="3" Padding="8,6">
                            <TextBlock Text="{Binding SelectedFilePath}"
                                       Foreground="{DynamicResource Theme.FgPrimary}"
                                       FontFamily="Consolas" FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="2" Content="📂 찾아보기..."
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BrowseFileCommand}"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Visibility="{Binding HasFile, Converter={StaticResource BoolToVisDlg}}">
                        <TextBlock Text="이름: " Foreground="{DynamicResource Theme.FgMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedFileName}"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="11"
                                   FontFamily="Consolas"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="크기: " Foreground="{DynamicResource Theme.FgMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedFileSize}"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="11"
                                   FontFamily="Consolas"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="형식: " Foreground="{DynamicResource Theme.FgMuted}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedFileFormat}"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="11"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════ Row 3: 커밋 카드 ════════ -->
            <Border Grid.Row="3" Style="{StaticResource DetailCard}" Padding="18,14" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                            Padding="10,0,0,0" Margin="0,0,0,12">
                        <TextBlock Text="3. 커밋"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgPrimary}"/>
                    </Border>

                    <Button Grid.Row="1" Content="✅ 임포트 커밋"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CommitImportCommand}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            FontSize="13"
                            FontWeight="Bold"
                            Margin="0,0,0,10"/>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Theme.BgGridRowOdd}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsResultSuccess}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Theme.BgCard}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsResultError}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Theme.BgCard}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ResultMessage}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsResultError}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Error}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════ Row 4: 보조 액션 ════════ -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="📁 빌더 출력 폴더 열기"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenOutputFolderCommand}"
                        Margin="0,0,8,0"
                        ToolTip="%APPDATA%/SPILab/NowMoment/kg_builder 를 탐색기에서 엽니다"/>
                <Button Content="🗑 현재 도메인 비우기"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearDomainCommand}"
                        ToolTip="선택된 도메인의 모든 KG 노드/엣지를 삭제 (도메인 자체는 보존)"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
