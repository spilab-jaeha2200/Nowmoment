<!-- ════════════════════════════════════════════════════════════
     KgNodeEditDialog.xaml — KG 노드 추가/편집 (v4 테마 호환)

     모든 색을 DynamicResource Theme.* 로 바인딩 → ThemeManager 가
     라이트/다크 팔레트로 덮어쓰면 자동 전환.
     컨트롤 이름(TxtId/CmbType/TxtLabel/TxtProps/TxtError)은 기존 유지.
     ════════════════════════════════════════════════════════════ -->
<Window x:Class="SPILab.NowMoment.Views.KgNodeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KG 노드 편집" Height="560" Width="640"
        MinHeight="480" MinWidth="540"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Theme.BgMain}"
        FontFamily="맑은 고딕"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- 필드 라벨 -->
        <Style x:Key="DlgLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 입력 TextBox -->
        <Style x:Key="DlgInput" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Cyan}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgDisabled}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Theme.FgMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- JSON 멀티라인 -->
        <Style x:Key="DlgInputCode" TargetType="TextBox" BasedOn="{StaticResource DlgInput}">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding"    Value="8,6"/>
        </Style>

        <!-- ComboBoxItem -->
        <Style x:Key="DlgComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 편집 가능 ComboBox -->
        <Style x:Key="DlgCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="IsEditable"      Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DlgComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="26"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource Theme.FgPrimary}"
                                             CaretBrush="{DynamicResource Theme.FgPrimary}"
                                             BorderThickness="0"
                                             Padding="8,0" Margin="0"
                                             VerticalContentAlignment="Center"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"/>
                                    <ToggleButton Grid.Column="1" Focusable="False"
                                                  ClickMode="Press"
                                                  Background="Transparent" BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                          Fill="{DynamicResource Theme.FgSecondary}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                                <Border Background="{DynamicResource Theme.BgCard}"
                                        BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Cyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 취소 버튼 (테두리형) -->
        <Style x:Key="DlgCancelBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="MinWidth"        Value="84"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 저장 버튼 (Accent 채움) -->
        <Style x:Key="DlgPrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgOnAccent}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="22,8"/>
            <Setter Property="MinWidth"        Value="84"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.AccentDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Theme.BgCard}"
            BorderBrush="{DynamicResource Theme.Border}"
            BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단 입력 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DlgLabel}">
                    <Run Text="ID "/>
                    <Run Text="*" Foreground="{DynamicResource Theme.Error}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtId"
                         Style="{StaticResource DlgInput}"
                         VerticalAlignment="Center"
                         ToolTip="rule:R6 / mat:GaN — prefix:local 권장"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource DlgLabel}">
                    <Run Text="타입 "/>
                    <Run Text="*" Foreground="{DynamicResource Theme.Error}"/>
                </TextBlock>
                <ComboBox Grid.Row="0" Grid.Column="4" x:Name="CmbType"
                          Style="{StaticResource DlgCombo}"
                          Loaded="EditableCombo_Loaded"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DlgLabel}">
                    <Run Text="레이블 "/>
                    <Run Text="*" Foreground="{DynamicResource Theme.Error}"/>
                </TextBlock>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4"
                         x:Name="TxtLabel"
                         Style="{StaticResource DlgInput}"
                         VerticalAlignment="Center"/>
            </Grid>

            <!-- props_json -->
            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="0,0,0,6"
                           Foreground="{DynamicResource Theme.FgSecondary}"
                           FontSize="12"
                           Text="속성 (props_json) — JSON 객체 형식"/>
                <TextBox Grid.Row="1" x:Name="TxtProps"
                         Style="{StaticResource DlgInputCode}"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- 오류 메시지 -->
            <TextBlock Grid.Row="2" x:Name="TxtError"
                       Foreground="{DynamicResource Theme.Error}"
                       FontSize="12" TextWrapping="Wrap"
                       Margin="0,10,0,0"/>

            <!-- 버튼 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="취소" IsCancel="True"
                        Style="{StaticResource DlgCancelBtn}"
                        Margin="0,0,10,0"/>
                <Button Content="저장" IsDefault="True"
                        Style="{StaticResource DlgPrimaryBtn}"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
