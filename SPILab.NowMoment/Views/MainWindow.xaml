<Window x:Class="SPILab.NowMoment.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:views="clr-namespace:SPILab.NowMoment.Views"
        Title="NowMoment v4.0 — 기술자산관리 시스템" Height="820" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1A2332">

    <Window.Resources>
        <!-- ▼ KG 탭에서 사용 -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- 색상 팔레트 -->
        <SolidColorBrush x:Key="NavyDark"   Color="#1A2332"/>
        <SolidColorBrush x:Key="NavyMid"    Color="#1F3150"/>
        <SolidColorBrush x:Key="NavyLight"  Color="#2A4A7F"/>
        <SolidColorBrush x:Key="Accent"     Color="#5BA3D9"/>
        <SolidColorBrush x:Key="AccentDark" Color="#2E75B6"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F0F4F8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9DB4CC"/>
        <SolidColorBrush x:Key="CardBg"     Color="#243447"/>
        <SolidColorBrush x:Key="RowEven"    Color="#1F3150"/>
        <SolidColorBrush x:Key="RowOdd"     Color="#243447"/>
        <SolidColorBrush x:Key="Green"      Color="#4CAF72"/>
        <SolidColorBrush x:Key="Orange"     Color="#E8A838"/>
        <SolidColorBrush x:Key="Red"        Color="#E85555"/>

        <!-- 기본 버튼 스타일 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2E75B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5BA3D9"/>
                            </Trigger>
                            <!-- v3.0: 비활성 상태 시각화 — 회색 톤으로 흐릿하게 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4A5C"/>
                                <Setter Property="Foreground" Value="#7E8FA0"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#8B2525"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E85555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#2A4A7F"/>
        </Style>

        <!-- TextBox 스타일 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A2B3C"/>
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#2E75B6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ComboBox 스타일 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A2B3C"/>
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#2E75B6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.ColumnSpan="2"
                                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    BorderThickness="1" CornerRadius="2"/>
                                            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#9DB4CC"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="8,6,28,6"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="#F0F4F8"
                                              TextElement.FontFamily="맑은 고딕"
                                              TextElement.FontSize="13"
                                              IsHitTestVisible="False"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="#1A2B3C" BorderBrush="#2E75B6" BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A2B3C"/>
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4A7F"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E75B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- DataGrid 스타일 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1F3150"/>
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#2A4A7F"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A4A7F"/>
            <Setter Property="RowBackground" Value="#1F3150"/>
            <Setter Property="AlternatingRowBackground" Value="#243447"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1F4E79"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#2A4A7F"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E75B6"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabItem 스타일 -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#9DB4CC"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,3" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5BA3D9"/>
                                <Setter Property="Foreground" Value="#F0F4F8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0F4F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label 기본 -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#9DB4CC"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── 헤더 바 ── -->
        <Border Grid.Row="0" Background="#1F3150" BorderBrush="#2E75B6"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="22" Foreground="#5BA3D9" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="NowMoment" FontSize="18" FontWeight="Bold"
                               Foreground="#F0F4F8" FontFamily="맑은 고딕" VerticalAlignment="Center"/>
                    <TextBlock Text="기술자산관리 시스템" FontSize="12" Foreground="#9DB4CC"
                               FontFamily="맑은 고딕" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <!-- 글로벌 검색 -->
                <Grid Grid.Column="1" HorizontalAlignment="Center" Width="440">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Background="#1A2B3C" Foreground="#F0F4F8" BorderBrush="#2E75B6"
                             Padding="12,8" FontSize="13" FontFamily="맑은 고딕"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍  전체 자산 검색 (코드·모델·문서·특허·실험)"
                                                                   Foreground="#5A7A9A" FontFamily="맑은 고딕" FontSize="13"
                                                                   Margin="12,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="1" Content="검색" Command="{Binding GlobalSearchCommand}"
                            Style="{StaticResource PrimaryBtn}" Width="64" Margin="6,0,0,0"/>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺  새로고침" Command="{Binding RefreshCommand}"
                            Style="{StaticResource GhostBtn}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 메인 탭 ── -->
        <TabControl Grid.Row="1" Background="#1A2332" BorderThickness="0"
                    SelectedIndex="{Binding SelectedTab}">

            <!-- 대시보드 -->
            <TabItem Header="대시보드">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1A2332">
                    <StackPanel Margin="30,24">
                        <TextBlock Text="기술자산 현황" FontSize="22" FontWeight="Bold"
                                   Foreground="#F0F4F8" FontFamily="맑은 고딕" Margin="0,0,0,20"/>
                        <!-- 통계 카드 -->
                        <WrapPanel>
                            <!-- 소스코드 카드 (청록) -->
                            <Border Background="#1E4D5C" CornerRadius="10" Margin="0,0,16,16"
                                    Width="170" Height="110" Padding="20,16"
                                    BorderBrush="#2EA4C7" BorderThickness="0,0,0,3">
                                <StackPanel VerticalAlignment="Center" DataContext="{Binding Stats[0]}">
                                    <TextBlock Text="{Binding Count}" FontSize="38" FontWeight="Bold"
                                               Foreground="#7DD8E8" FontFamily="맑은 고딕"/>
                                    <TextBlock Text="{Binding Label}" FontSize="14"
                                               Foreground="#B5D8E0" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- 모델 카드 (보라) -->
                            <Border Background="#3D2C5C" CornerRadius="10" Margin="0,0,16,16"
                                    Width="170" Height="110" Padding="20,16"
                                    BorderBrush="#8B6FBF" BorderThickness="0,0,0,3">
                                <StackPanel VerticalAlignment="Center" DataContext="{Binding Stats[1]}">
                                    <TextBlock Text="{Binding Count}" FontSize="38" FontWeight="Bold"
                                               Foreground="#C9B0F0" FontFamily="맑은 고딕"/>
                                    <TextBlock Text="{Binding Label}" FontSize="14"
                                               Foreground="#D8C8E8" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- 문서 카드 (그린) -->
                            <Border Background="#1E4D38" CornerRadius="10" Margin="0,0,16,16"
                                    Width="170" Height="110" Padding="20,16"
                                    BorderBrush="#4CAF72" BorderThickness="0,0,0,3">
                                <StackPanel VerticalAlignment="Center" DataContext="{Binding Stats[2]}">
                                    <TextBlock Text="{Binding Count}" FontSize="38" FontWeight="Bold"
                                               Foreground="#8FE0A8" FontFamily="맑은 고딕"/>
                                    <TextBlock Text="{Binding Label}" FontSize="14"
                                               Foreground="#B8D8C0" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- 특허 카드 (오렌지) -->
                            <Border Background="#5C3D1E" CornerRadius="10" Margin="0,0,16,16"
                                    Width="170" Height="110" Padding="20,16"
                                    BorderBrush="#E8A838" BorderThickness="0,0,0,3">
                                <StackPanel VerticalAlignment="Center" DataContext="{Binding Stats[3]}">
                                    <TextBlock Text="{Binding Count}" FontSize="38" FontWeight="Bold"
                                               Foreground="#F5C97A" FontFamily="맑은 고딕"/>
                                    <TextBlock Text="{Binding Label}" FontSize="14"
                                               Foreground="#E0CCA8" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- 실험 카드 (핑크/레드) -->
                            <Border Background="#5C2538" CornerRadius="10" Margin="0,0,16,16"
                                    Width="170" Height="110" Padding="20,16"
                                    BorderBrush="#E85577" BorderThickness="0,0,0,3">
                                <StackPanel VerticalAlignment="Center" DataContext="{Binding Stats[4]}">
                                    <TextBlock Text="{Binding Count}" FontSize="38" FontWeight="Bold"
                                               Foreground="#F590A8" FontFamily="맑은 고딕"/>
                                    <TextBlock Text="{Binding Label}" FontSize="14"
                                               Foreground="#E8C0CC" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- 검색 결과 (글로벌) -->
                        <TextBlock Text="검색 결과" FontSize="18" FontWeight="Bold"
                                   Foreground="#F0F4F8" FontFamily="맑은 고딕" Margin="0,24,0,12"/>
                        <DataGrid ItemsSource="{Binding SearchResults}" Height="340">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="유형"        Binding="{Binding AssetType}" Width="70"/>
                                <DataGridTextColumn Header="자산명"      Binding="{Binding Name}"      Width="*"/>
                                <DataGridTextColumn Header="프로젝트"    Binding="{Binding ProjectName}" Width="180"/>
                                <DataGridTextColumn Header="태그"        Binding="{Binding Tags}"       Width="130"/>
                                <DataGridTextColumn Header="등록일"      Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 소스코드 탭 -->
            <TabItem Header="소스코드">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBox Width="300" Text="{Binding CodeKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0"/>
                            <Button Content="+ 소스코드 등록" Command="{Binding AddCodeCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <!-- v3.0 F-002: 자산 탭별 폴더 임포트 (소스코드만 prefilter) -->
                            <Button Content="📁  폴더 임포트"
                                    Command="{Binding FolderImportCommand}"
                                    CommandParameter="code"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="로컬 폴더에서 소스코드 자산 자동 검출 + 일괄 등록"/>
                        </StackPanel>
                        <!-- v3.0 F-003 + F-004: 우상단 DB 백업 + 카탈로그 출력 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾  DB 백업" Command="{Binding BackupDbCommand}"
                                    Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                    ToolTip="현재 DB(nowmoment.db) 전체를 zip 파일로 백업"/>
                            <Button Content="📑  카탈로그 출력"
                                    Command="{Binding ExportPdfCatalogCommand}"
                                    CommandParameter="code"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="자산 전체 + KG 통계를 통합 PDF 카탈로그로 출력"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Codes}" SelectedItem="{Binding SelectedCode, Mode=TwoWay}" x:Name="CodeGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding Id}"          Width="50"/>
                            <DataGridTextColumn Header="자산명"     Binding="{Binding Name}"         Width="*"/>
                            <DataGridTextColumn Header="언어"       Binding="{Binding Language}"     Width="80"/>
                            <DataGridTextColumn Header="버전"       Binding="{Binding Version}"      Width="80"/>
                            <DataGridTextColumn Header="프로젝트"   Binding="{Binding ProjectName}"  Width="200"/>
                            <DataGridTextColumn Header="태그"       Binding="{Binding Tags}"         Width="160"/>
                            <DataGridTextColumn Header="등록일"     Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTemplateColumn Header="관리" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="수정" Margin="2"
                                                    Command="{Binding DataContext.EditCodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostBtn}" Padding="8,4"/>
                                            <Button Content="삭제" Margin="2"
                                                    Command="{Binding DataContext.DeleteCodeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerBtn}" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- AI 모델 탭 -->
            <TabItem Header="AI 모델">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBox Width="300" Text="{Binding ModelKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="+ 모델 등록" Command="{Binding AddModelCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <!-- v3.0 F-002: 자산 탭별 폴더 임포트 -->
                            <Button Content="📁  폴더 임포트"
                                    Command="{Binding FolderImportCommand}"
                                    CommandParameter="model"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="로컬 폴더에서 AI 모델 자산 자동 검출 + 일괄 등록"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾  DB 백업" Command="{Binding BackupDbCommand}"
                                    Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                    ToolTip="현재 DB(nowmoment.db) 전체를 zip 파일로 백업"/>
                            <Button Content="📑  카탈로그 출력"
                                    Command="{Binding ExportPdfCatalogCommand}"
                                    CommandParameter="model"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="자산 전체 + KG 통계를 통합 PDF 카탈로그로 출력"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"       Width="50"/>
                            <DataGridTextColumn Header="모델명"      Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="프레임워크"  Binding="{Binding Framework}" Width="100"/>
                            <DataGridTextColumn Header="정확도"      Binding="{Binding Accuracy, StringFormat=P2}" Width="80"/>
                            <DataGridTextColumn Header="프로젝트"    Binding="{Binding ProjectName}" Width="180"/>
                            <DataGridTextColumn Header="기반모델"    Binding="{Binding BaseModel}" Width="130"/>
                            <DataGridTextColumn Header="등록일"      Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTemplateColumn Header="관리" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="수정" Margin="2"
                                                    Command="{Binding DataContext.EditModelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,4"/>
                                            <Button Content="삭제" Margin="2"
                                                    Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource DangerBtn}" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 문서 탭 -->
            <TabItem Header="문서·논문">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBox Width="300" Text="{Binding DocKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="+ 문서 등록" Command="{Binding AddDocumentCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <!-- v3.0 F-002: 자산 탭별 폴더 임포트 -->
                            <Button Content="📁  폴더 임포트"
                                    Command="{Binding FolderImportCommand}"
                                    CommandParameter="document"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="로컬 폴더에서 문서·논문 자산 자동 검출 + 일괄 등록"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾  DB 백업" Command="{Binding BackupDbCommand}"
                                    Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                    ToolTip="현재 DB(nowmoment.db) 전체를 zip 파일로 백업"/>
                            <Button Content="📑  카탈로그 출력"
                                    Command="{Binding ExportPdfCatalogCommand}"
                                    CommandParameter="document"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="자산 전체 + KG 통계를 통합 PDF 카탈로그로 출력"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="50"/>
                            <DataGridTextColumn Header="제목"     Binding="{Binding Title}"    Width="*"/>
                            <DataGridTextColumn Header="유형"     Binding="{Binding DocType}"  Width="90"/>
                            <DataGridTextColumn Header="버전"     Binding="{Binding Version}"  Width="70"/>
                            <DataGridTextColumn Header="프로젝트" Binding="{Binding ProjectName}" Width="180"/>
                            <DataGridTextColumn Header="요약"     Binding="{Binding Summary}"  Width="200"/>
                            <DataGridTextColumn Header="등록일"   Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTemplateColumn Header="관리" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="수정" Margin="2"
                                                    Command="{Binding DataContext.EditDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,4"/>
                                            <Button Content="삭제" Margin="2"
                                                    Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource DangerBtn}" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 특허 탭 -->
            <TabItem Header="특허·IP">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBox Width="300" Text="{Binding PatentKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="+ 특허 등록" Command="{Binding AddPatentCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <!-- v3.0 F-002: 특허는 폴더에서 출원번호/출원일/발명자 추출 불가 → 비활성 -->
                            <Button Content="📁  폴더 임포트"
                                    IsEnabled="False"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="특허는 출원번호·출원일·발명자 등 폴더에서 자동 추출이 불가능한 메타데이터가 필수이므로 수동 등록만 지원합니다."/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾  DB 백업" Command="{Binding BackupDbCommand}"
                                    Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                    ToolTip="현재 DB(nowmoment.db) 전체를 zip 파일로 백업"/>
                            <Button Content="📑  카탈로그 출력"
                                    Command="{Binding ExportPdfCatalogCommand}"
                                    CommandParameter="patent"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="자산 전체 + KG 통계를 통합 PDF 카탈로그로 출력"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Patents}" SelectedItem="{Binding SelectedPatent, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"             Width="50"/>
                            <DataGridTextColumn Header="특허명"   Binding="{Binding Title}"          Width="*"/>
                            <DataGridTextColumn Header="출원번호" Binding="{Binding ApplicationNo}"  Width="150"/>
                            <DataGridTextColumn Header="상태"     Binding="{Binding Status}"         Width="90"/>
                            <DataGridTextColumn Header="출원일"   Binding="{Binding FilingDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="발명자"   Binding="{Binding Inventors}"      Width="160"/>
                            <DataGridTemplateColumn Header="관리" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="수정" Margin="2"
                                                    Command="{Binding DataContext.EditPatentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,4"/>
                                            <Button Content="삭제" Margin="2"
                                                    Command="{Binding DataContext.DeletePatentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource DangerBtn}" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- 실험 결과 탭 -->
            <TabItem Header="실험결과">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBox Width="300" Text="{Binding ExpKeyword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="+ 실험 등록" Command="{Binding AddExperimentCommand}" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <!-- v3.0 F-002: 자산 탭별 폴더 임포트 -->
                            <Button Content="📁  폴더 임포트"
                                    Command="{Binding FolderImportCommand}"
                                    CommandParameter="experiment"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="로컬 폴더에서 실험 자산(metrics.json+params.json) 자동 검출 + 일괄 등록"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾  DB 백업" Command="{Binding BackupDbCommand}"
                                    Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                    ToolTip="현재 DB(nowmoment.db) 전체를 zip 파일로 백업"/>
                            <Button Content="📑  카탈로그 출력"
                                    Command="{Binding ExportPdfCatalogCommand}"
                                    CommandParameter="experiment"
                                    Style="{StaticResource GhostBtn}"
                                    ToolTip="자산 전체 + KG 통계를 통합 PDF 카탈로그로 출력"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Experiments}" SelectedItem="{Binding SelectedExperiment, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding Id}"         Width="50"/>
                            <DataGridTextColumn Header="실험명"     Binding="{Binding Name}"       Width="*"/>
                            <DataGridTextColumn Header="참조자산"   Binding="{Binding AssetRef}"   Width="160"/>
                            <DataGridTextColumn Header="상태"       Binding="{Binding Status}"     Width="90"/>
                            <DataGridTextColumn Header="지표(JSON)" Binding="{Binding Metrics}"    Width="240"/>
                            <DataGridTextColumn Header="등록일"     Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTemplateColumn Header="관리" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="수정" Margin="2"
                                                    Command="{Binding DataContext.EditExperimentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource GhostBtn}" Padding="8,4"/>
                                            <Button Content="삭제" Margin="2"
                                                    Command="{Binding DataContext.DeleteExperimentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource DangerBtn}" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ▼ 여기서부터 KgTab.xaml 본문 붙여넣기 -->
            <TabItem Header="지식그래프 (KG)">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ══════════════════════════════════════════════════════
                        컨트롤 바 (두 줄): 1행=도메인+액션+상태,  2행=필터+그래프토글
                        ══════════════════════════════════════════════════════ -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">

                        <!-- ── 1행: 도메인 / 빌더 / 데이터 / 상태 ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                            <!-- ───── 그룹 0: 도메인 (선택 + 추가/삭제/비우기) ───── -->
                            <TextBlock Text="도메인:" Foreground="{StaticResource TextSecondary}"
                                    VerticalAlignment="Center" Margin="0,0,6,0" FontFamily="맑은 고딕"/>

                            <ComboBox x:Name="CmbDomain" Width="240"
                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                    ItemsSource="{Binding Kg.Domains}"
                                    DisplayMemberPath="Label"
                                    SelectedValuePath="Code"
                                    SelectedValue="{Binding Kg.SelectedDomain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="KG 도메인 — 도메인별로 노드/엣지/빌더가 분리됩니다."/>

                            <Button Content="+ 도메인" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.AddDomainCommand}" Margin="0,0,4,0"
                                    ToolTip="새 KG 도메인 등록 (TTL/JSON 자동 임포트도 함께 가능)"/>
                            <Button Content="– 도메인" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.DeleteDomainCommand}" Margin="0,0,4,0"
                                    ToolTip="현재 사용자 도메인 삭제 (빌트인 5종은 삭제 불가)"/>

                            <!-- ★ v2.7.3: [도메인 비우기] 도메인 그룹으로 이동 -->
                            <Button Content="도메인 비우기" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.ClearDomainCommand}" Margin="0,0,12,0"
                                    Foreground="#F590A8"
                                    ToolTip="현재 도메인의 KG 노드/엣지를 모두 삭제 (도메인 자체는 보존)"/>

                            <Border Width="1" Height="22" Background="#2A3F54" Margin="0,0,12,0"/>

                            <!-- ───── 그룹 1: 빌더 액션 ───── -->
                            <Button Content="KG 빌드" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding Kg.BuildCommand}" Margin="0,0,8,0"
                                    ToolTip="현재 도메인의 build_kg_*.py 실행"/>
                            <Button Content="경로변경" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.ChangeBuilderSrcCommand}" Margin="0,0,8,0"
                                    ToolTip="{Binding Kg.BuilderSrcPath, TargetNullValue='(미선택 — 첫 빌드 시 선택)', FallbackValue='(미선택)'}"/>

                            <Border Width="1" Height="22" Background="#2A3F54" Margin="4,0,12,0"/>

                            <!-- ───── 그룹 2: 데이터 액션 ───── -->
                            <Button Content="KG 임포트" Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding Kg.ImportCommand}" Margin="0,0,4,0"
                                    ToolTip="현재 도메인의 빌더 출력 JSON 을 자동 경로에서 임포트"/>

                            <!-- ★ v2.7.3: TTL/JSON 임포트 버튼 숨김 — 도메인 등록 팝업에 통합됨.
                                기존 사용자가 다른 도메인에 별도 파일 임포트하려면
                                이 Visibility 만 다시 풀어주면 즉시 복원된다. -->
                            <Button Content="TTL/JSON 임포트" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.ImportFileCommand}" Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    ToolTip="(숨김) TTL/RDF/JSON-LD 파일 직접 선택 임포트"/>

                            <Button Content="새로고침" Style="{StaticResource GhostBtn}"
                                    Command="{Binding Kg.RefreshCommand}" Margin="0,0,8,0"
                                    ToolTip="DB 에서 KG 노드/엣지 재조회"/>

                            <TextBlock Text="{Binding Kg.ImportStatus}" Foreground="{StaticResource Accent}"
                                    VerticalAlignment="Center" Margin="20,0,0,0"
                                    FontFamily="맑은 고딕" FontSize="12"
                                    MaxWidth="240" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Kg.BuildStatus}" Foreground="{StaticResource Accent}"
                                    VerticalAlignment="Center" Margin="8,0,0,0"
                                    FontFamily="맑은 고딕" FontSize="12"
                                    MaxWidth="240" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- ── 2행: 필터/검색 / 그래프 토글 ── -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="유형:" Foreground="{StaticResource TextSecondary}"
                                    VerticalAlignment="Center" Margin="0,0,6,0" FontFamily="맑은 고딕"/>
                            <ComboBox Width="140" ItemsSource="{Binding Kg.NodeTypes}"
                                    SelectedItem="{Binding Kg.TypeFilter, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,12,0"/>

                            <TextBlock Text="검색:" Foreground="{StaticResource TextSecondary}"
                                    VerticalAlignment="Center" Margin="0,0,6,0" FontFamily="맑은 고딕"/>
                            <TextBox Width="220" Text="{Binding Kg.Keyword, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>

                            <Border Width="1" Height="22" Background="#2A3F54" Margin="12,0,12,0"/>

                            <ToggleButton x:Name="GraphViewToggle"
                                        Content="그래프 보기"
                                        Padding="10,4"
                                        Background="Transparent" Foreground="#9DB4CC"
                                        BorderBrush="#2E75B6" BorderThickness="1"
                                        FontFamily="맑은 고딕" FontSize="12"
                                        ToolTip="목록 보기 ↔ 그래프 보기 전환"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ══════════════════════════════════════════════════════
                        통계 카드 (노드 타입별 / 엣지 관계별)  ※ 변경 없음
                        ══════════════════════════════════════════════════════ -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="8"
                                Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="노드 통계 (타입별)" Foreground="{StaticResource TextPrimary}"
                                        FontFamily="맑은 고딕" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Kg.StatsByType}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E4D5C" Margin="0,0,8,4" Padding="10,4"
                                                    CornerRadius="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Key}" Foreground="#7DD8E8"
                                                            FontFamily="맑은 고딕" FontSize="12"/>
                                                    <TextBlock Text=" : " Foreground="{StaticResource TextSecondary}"
                                                            FontFamily="맑은 고딕" FontSize="12"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="White"
                                                            FontFamily="맑은 고딕" FontSize="12" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="8"
                                Padding="16,12" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="엣지 통계 (관계별)" Foreground="{StaticResource TextPrimary}"
                                        FontFamily="맑은 고딕" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Kg.StatsByRel}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#5C2538" Margin="0,0,8,4" Padding="10,4"
                                                    CornerRadius="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Key}" Foreground="#F590A8"
                                                            FontFamily="Consolas" FontSize="11"/>
                                                    <TextBlock Text=" : " Foreground="{StaticResource TextSecondary}"
                                                            FontFamily="맑은 고딕" FontSize="12"/>
                                                    <TextBlock Text="{Binding Count}" Foreground="White"
                                                            FontFamily="맑은 고딕" FontSize="12" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ══════════════════════════════════════════════════════
                        메인 그리드: 노드 목록 (좌) + 디테일 패널 (우)  — 목록 모드
                        ══════════════════════════════════════════════════════ -->
                    <Grid Grid.Row="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=GraphViewToggle}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 좌측: 노드 목록 (헤더 + 액션 + 그리드) -->
                        <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="8"
                                Padding="16,12" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="KG 노드"
                                            Foreground="{StaticResource TextPrimary}"
                                            FontFamily="맑은 고딕" FontSize="13" FontWeight="Bold"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Kg.Nodes.Count, StringFormat=' ({0})'}"
                                            Foreground="{StaticResource TextSecondary}"
                                            FontFamily="맑은 고딕" FontSize="12"
                                            VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 노드 추가" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.AddNodeCommand}" Margin="0,0,8,0"
                                            ToolTip="현재 도메인에 새 KG 노드 추가"/>
                                    <Button Content="노드 편집" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.EditNodeCommand}" Margin="0,0,8,0"
                                            ToolTip="선택된 노드의 타입/레이블/props 수정"/>
                                    <Button Content="선택 노드 삭제" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.DeleteNodeCommand}"
                                            Foreground="#F590A8" Margin="0,0,0,0"
                                            ToolTip="선택된 노드를 삭제 (인접 엣지/자산링크 포함)"/>
                                </StackPanel>

                                <DataGrid Grid.Row="2"
                                        ItemsSource="{Binding Kg.Nodes}"
                                        SelectedItem="{Binding Kg.SelectedNode}"
                                        AutoGenerateColumns="False" IsReadOnly="True"
                                        HeadersVisibility="Column"
                                        Background="Transparent" BorderThickness="0"
                                        GridLinesVisibility="None"
                                        RowBackground="#1F3150" AlternatingRowBackground="#243447"
                                        Foreground="{StaticResource TextPrimary}"
                                        FontFamily="맑은 고딕" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"     Binding="{Binding Id}"    Width="120"/>
                                        <DataGridTextColumn Header="타입"   Binding="{Binding Type}"  Width="110"/>
                                        <DataGridTextColumn Header="레이블" Binding="{Binding Label}" Width="*"/>
                                    </DataGrid.Columns>

                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="노드 추가..."  Command="{Binding Kg.AddNodeCommand}"/>
                                            <MenuItem Header="노드 편집..."  Command="{Binding Kg.EditNodeCommand}"/>
                                            <MenuItem Header="노드 삭제"     Command="{Binding Kg.DeleteNodeCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="이 노드에서 시작하는 엣지 추가..."
                                                    Command="{Binding Kg.AddEdgeCommand}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- 우측: 디테일 패널 -->
                        <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="8"
                                Padding="16,12" Margin="8,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>   <!-- 0: 선택된 노드 라벨 -->
                                    <RowDefinition Height="Auto"/>   <!-- 1: 자산 링크 버튼 -->
                                    <RowDefinition Height="Auto"/>   <!-- 2: 노드 속성 JSON -->
                                    <RowDefinition Height="Auto"/>   <!-- 3: 엣지 추가/삭제 버튼 -->
                                    <RowDefinition Height="*"/>      <!-- 4: 인접 엣지 그리드 -->
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="선택된 노드:"
                                            Foreground="{StaticResource TextSecondary}"
                                            FontFamily="맑은 고딕" FontSize="12" Margin="0,0,8,0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Kg.SelectedNode.Label, FallbackValue='(없음)'}"
                                            Foreground="{StaticResource TextPrimary}"
                                            FontFamily="맑은 고딕" FontSize="14" FontWeight="Bold"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text=" / " Foreground="{StaticResource TextSecondary}"
                                            FontFamily="맑은 고딕" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Kg.SelectedNode.Type}"
                                            Foreground="{StaticResource Accent}"
                                            FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1: 자산 링크 (link_type 콤보 + 버튼) — 위로 올림 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <ComboBox Width="120" Margin="0,0,4,0"
                                              ItemsSource="{Binding Kg.LinkTypes}"
                                              SelectedItem="{Binding Kg.SelectedLinkType, Mode=TwoWay}"
                                              ToolTip="자산↔KG 노드 사이의 관계 종류"/>
                                    <Button Content="현재 자산에 링크"
                                            Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.LinkSelectedAssetCmd}"
                                            ToolTip="자산 탭에서 선택한 자산과 위에서 선택한 KG 노드를, 콤보박스의 관계로 연결합니다."/>
                                </StackPanel>

                                <Border Grid.Row="2" Background="#1A2B3C" CornerRadius="4"
                                        Padding="10,8" Margin="0,0,0,10">
                                    <DockPanel>
                                        <!-- 노드 속성 (JSON) — 상단 -->
                                        <ScrollViewer DockPanel.Dock="Top"
                                                      MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                                      Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Kg.SelectedNodeProps}"
                                                    Foreground="#7DD8E8"
                                                    FontFamily="Consolas" FontSize="11"
                                                    TextWrapping="Wrap"/>
                                        </ScrollViewer>

                                        <!-- v3.0 F-001 Step 1.7: 이 노드에 연결된 자산 목록 — 하단 -->
                                        <Border DockPanel.Dock="Bottom"
                                                BorderBrush="#FFB300" BorderThickness="0,1,0,0"
                                                Padding="0,6,0,0"
                                                Visibility="{Binding Kg.HasLinkedAssets,
                                                             Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Top"
                                                           Text="🔗 이 노드에 연결된 자산"
                                                           Foreground="#FFB300"
                                                           FontFamily="맑은 고딕" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <DataGrid ItemsSource="{Binding Kg.LinkedAssetsForSelectedNode}"
                                                          AutoGenerateColumns="False" IsReadOnly="True"
                                                          HeadersVisibility="Column"
                                                          Background="Transparent" BorderThickness="0"
                                                          GridLinesVisibility="Horizontal"
                                                          RowBackground="#1F3150" AlternatingRowBackground="#243447"
                                                          Foreground="{StaticResource TextPrimary}"
                                                          FontFamily="맑은 고딕" FontSize="11"
                                                          MaxHeight="140">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="유형"
                                                            Binding="{Binding AssetTypeLabel}" Width="60"/>
                                                        <DataGridTextColumn Header="자산명"
                                                            Binding="{Binding AssetName}" Width="*"/>
                                                        <DataGridTextColumn Header="관계"
                                                            Binding="{Binding LinkType}" Width="90"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                </Border>

                                <!-- Row 3: 엣지 추가/삭제 (그리드 바로 위) -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 엣지 추가" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.AddEdgeCommand}" Margin="0,0,8,0"
                                            ToolTip="선택된 노드에서 시작하는 새 엣지를 추가"/>
                                    <Button Content="선택 엣지 삭제" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Kg.DeleteEdgeCommand}"
                                            CommandParameter="{Binding SelectedItem, ElementName=EdgeGrid}"
                                            Foreground="#F590A8"
                                            ToolTip="아래 인접 엣지 그리드에서 선택한 엣지를 삭제"/>
                                </StackPanel>

                                <DataGrid Grid.Row="4" x:Name="EdgeGrid"
                                        ItemsSource="{Binding Kg.Edges}"
                                        AutoGenerateColumns="False" IsReadOnly="True"
                                        HeadersVisibility="Column"
                                        Background="Transparent" BorderThickness="0"
                                        GridLinesVisibility="Horizontal"
                                        RowBackground="#1F3150" AlternatingRowBackground="#243447"
                                        Foreground="{StaticResource TextPrimary}"
                                        FontFamily="맑은 고딕" FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="From"     Binding="{Binding SrcLabel}" Width="*"/>
                                        <DataGridTextColumn Header="관계"     Binding="{Binding Rel}"      Width="120"/>
                                        <DataGridTextColumn Header="To"       Binding="{Binding DstLabel}" Width="*"/>
                                        <DataGridTextColumn Header="From타입" Binding="{Binding SrcType}"  Width="90"/>
                                        <DataGridTextColumn Header="To타입"   Binding="{Binding DstType}"  Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <views:KgGraphView Grid.Row="2"
                                    DataContext="{Binding Kg}"
                                    Visibility="{Binding IsChecked, ElementName=GraphViewToggle, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </TabItem>
            <!-- ▲ KgTab 끝 -->

            <!-- ▼ v3.0 F-005: TTL Studio 탭 ▼ -->
            <TabItem Header="TTL Studio" DataContext="{Binding TtlStudio}">
                <TabItem.Resources>
                    <!-- 입력 컨트롤 다크 테마 -->
                    <Style x:Key="StudioLabel" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#9DB4CC"/>
                        <Setter Property="FontFamily" Value="맑은 고딕"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="StudioTextBox" TargetType="TextBox">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#F0F4F8"/>
                        <Setter Property="BorderBrush" Value="#2E75B6"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding"     Value="6,4"/>
                        <Setter Property="FontFamily"  Value="맑은 고딕"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="CaretBrush"  Value="White"/>
                    </Style>
                    <Style x:Key="StudioCodeBox" TargetType="TextBox">
                        <Setter Property="Background"  Value="#0F1A28"/>
                        <Setter Property="Foreground"  Value="#A0E0FF"/>
                        <Setter Property="BorderBrush" Value="#2E75B6"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding"     Value="10,8"/>
                        <Setter Property="FontFamily"  Value="Consolas"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="CaretBrush"  Value="White"/>
                        <Setter Property="AcceptsReturn" Value="True"/>
                        <Setter Property="AcceptsTab"   Value="True"/>
                        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                        <Setter Property="TextWrapping" Value="NoWrap"/>
                    </Style>
                    <Style x:Key="StudioBtn" TargetType="Button">
                        <Setter Property="Background"  Value="#2A4A7F"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontFamily"  Value="맑은 고딕"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="12,6"/>
                        <Setter Property="Cursor"      Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#243447"/>
                                <Setter Property="Foreground" Value="#5A7A9A"/>
                                <Setter Property="Cursor"     Value="Arrow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="StudioPrimaryBtn" TargetType="Button" BasedOn="{StaticResource StudioBtn}">
                        <Setter Property="Background" Value="#2E75B6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                    <Style x:Key="StudioDangerBtn" TargetType="Button" BasedOn="{StaticResource StudioBtn}">
                        <Setter Property="Background" Value="#7F2A4A"/>
                    </Style>

                    <!-- ComboBox 다크 테마 -->
                    <Style x:Key="StudioComboToggle" TargetType="ToggleButton">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="ClickMode" Value="Press"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="#243447" BorderBrush="#2E75B6"
                                            BorderThickness="1" CornerRadius="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="#9DB4CC" HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="StudioComboItem" TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#F0F4F8"/>
                        <Setter Property="Padding"     Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E75B6"/>
                                        </Trigger>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E75B6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="StudioCombo" TargetType="ComboBox">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#F0F4F8"/>
                        <Setter Property="BorderBrush" Value="#2E75B6"/>
                        <Setter Property="FontFamily"  Value="맑은 고딕"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="6,4"/>
                        <Setter Property="ItemContainerStyle" Value="{StaticResource StudioComboItem}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <ToggleButton Style="{StaticResource StudioComboToggle}"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                                          RelativeSource={RelativeSource TemplatedParent}}"/>
                                        <ContentPresenter
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            IsHitTestVisible="False"
                                            Margin="8,4,24,4"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            TextElement.Foreground="#F0F4F8"/>
                                        <Popup Placement="Bottom"
                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                               AllowsTransparency="True"
                                               Focusable="False"
                                               PopupAnimation="Slide">
                                            <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  MinWidth="{TemplateBinding ActualWidth}">
                                                <Border Background="#243447" BorderBrush="#2E75B6"
                                                        BorderThickness="1" CornerRadius="2">
                                                    <ScrollViewer SnapsToDevicePixels="True">
                                                        <ItemsPresenter
                                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- DataGrid 셀 / 헤더 -->
                    <Style x:Key="StudioGridHeader" TargetType="DataGridColumnHeader">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#7DD8E8"/>
                        <Setter Property="FontFamily"  Value="맑은 고딕"/>
                        <Setter Property="FontSize"    Value="11"/>
                        <Setter Property="FontWeight"  Value="SemiBold"/>
                        <Setter Property="Padding"     Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#1A2B3C"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                    <Style x:Key="StudioGridCell" TargetType="DataGridCell">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Foreground"  Value="#F0F4F8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"     Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2E75B6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <!-- 서브 TabItem 다크 테마 -->
                    <Style x:Key="StudioSubTabItem" TargetType="TabItem">
                        <Setter Property="Background"  Value="#243447"/>
                        <Setter Property="Foreground"  Value="#9DB4CC"/>
                        <Setter Property="FontFamily"  Value="맑은 고딕"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="#2E75B6" BorderThickness="0,0,0,2"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1F2D40"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#7DD8E8"/>
                                            <Setter Property="Foreground" Value="#7DD8E8"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#F0F4F8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabItem.Resources>

                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- 헤더 (액션 + 메타) -->
                        <RowDefinition Height="*"/>      <!-- 본문 (서브 탭) -->
                        <RowDefinition Height="Auto"/>   <!-- 상태 메시지 -->
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Border Grid.Row="0" Background="#1F2D40" CornerRadius="3" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 1행: 파일 액션 + Summary -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Button Content="📂  열기" Command="{Binding OpenFileCommand}"
                                        Style="{StaticResource StudioBtn}" Margin="0,0,6,0"
                                        ToolTip="기존 .ttl 파일 열기"/>
                                <Button Content="💾  저장" Command="{Binding SaveFileCommand}"
                                        Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"
                                        ToolTip="현재 경로에 저장 (없으면 다른 이름으로 저장)"/>
                                <Button Content="💾  다른 이름으로..." Command="{Binding SaveAsCommand}"
                                        Style="{StaticResource StudioBtn}" Margin="0,0,6,0"/>
                                <Button Content="🆕  새로 시작" Command="{Binding NewOntologyCommand}"
                                        Style="{StaticResource StudioBtn}" Margin="0,0,6,0"
                                        ToolTip="모든 항목을 비우고 새 온톨로지 시작"/>

                                <Border Width="1" Background="#2E75B6" Margin="6,4"/>

                                <TextBlock Text="📊" VerticalAlignment="Center" Margin="6,0,4,0" FontSize="14"/>
                                <TextBlock Text="{Binding Summary}" Style="{StaticResource StudioLabel}"
                                           FontSize="12" Foreground="#7DD8E8" FontWeight="SemiBold"/>

                                <Border Width="1" Background="#2E75B6" Margin="14,4,6,4"/>

                                <TextBlock Text="{Binding WindowTitle}" VerticalAlignment="Center"
                                           Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11"
                                           Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- 2행: 네임스페이스 -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="base IRI:" Style="{StaticResource StudioLabel}"/>
                                <TextBox   Grid.Column="1" Style="{StaticResource StudioTextBox}"
                                           Text="{Binding BaseUri, UpdateSourceTrigger=LostFocus}"/>
                                <TextBlock Grid.Column="3" Text="prefix:" Style="{StaticResource StudioLabel}"/>
                                <TextBox   Grid.Column="4" Style="{StaticResource StudioTextBox}"
                                           Text="{Binding BasePrefix, UpdateSourceTrigger=LostFocus}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 본문: 5개 서브탭 -->
                    <TabControl Grid.Row="1" Background="Transparent"
                                BorderBrush="#2E75B6" BorderThickness="0,1,0,0">

                        <!-- 서브탭 1: Class -->
                        <TabItem Header="🎯 Class" Style="{StaticResource StudioSubTabItem}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 추가" Command="{Binding AddClassCommand}"
                                            Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"/>
                                    <Button Content="✗ 삭제" Command="{Binding RemoveClassCommand}"
                                            Style="{StaticResource StudioDangerBtn}"/>
                                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                               Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11">
                                        <Run Text="총 "/>
                                        <Run Text="{Binding Classes.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" 개 클래스"/>
                                    </TextBlock>
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Classes}"
                                          SelectedItem="{Binding SelectedClass, Mode=TwoWay}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Background="#1A2B3C" BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A4A7F"
                                          RowBackground="#1A2B3C" AlternatingRowBackground="#243447"
                                          ColumnHeaderStyle="{StaticResource StudioGridHeader}"
                                          CellStyle="{StaticResource StudioGridCell}"
                                          FontFamily="맑은 고딕" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="LocalName *" Width="180"
                                            Binding="{Binding LocalName, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Label (rdfs:label)" Width="200"
                                            Binding="{Binding Label, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Comment (rdfs:comment)" Width="*"
                                            Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="ParentClass" Width="160"
                                            Binding="{Binding ParentClass, UpdateSourceTrigger=LostFocus}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 서브탭 2: Property -->
                        <TabItem Header="🔗 Property" Style="{StaticResource StudioSubTabItem}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 추가" Command="{Binding AddPropertyCommand}"
                                            Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"/>
                                    <Button Content="✗ 삭제" Command="{Binding RemovePropertyCommand}"
                                            Style="{StaticResource StudioDangerBtn}"/>
                                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                               Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11">
                                        <Run Text="총 "/>
                                        <Run Text="{Binding Properties.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" 개 속성"/>
                                    </TextBlock>
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Properties}"
                                          SelectedItem="{Binding SelectedProperty, Mode=TwoWay}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Background="#1A2B3C" BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A4A7F"
                                          RowBackground="#1A2B3C" AlternatingRowBackground="#243447"
                                          ColumnHeaderStyle="{StaticResource StudioGridHeader}"
                                          CellStyle="{StaticResource StudioGridCell}"
                                          FontFamily="맑은 고딕" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="LocalName *" Width="160"
                                            Binding="{Binding LocalName, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Label" Width="160"
                                            Binding="{Binding Label, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTemplateColumn Header="Kind" Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Style="{StaticResource StudioCombo}"
                                                              SelectedItem="{Binding KindLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                        <sys:String>ObjectProperty</sys:String>
                                                        <sys:String>DatatypeProperty</sys:String>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Domain (클래스)" Width="140"
                                            Binding="{Binding Domain, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Range" Width="140"
                                            Binding="{Binding Range, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Comment" Width="*"
                                            Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 서브탭 3: Instance -->
                        <TabItem Header="📌 Instance" Style="{StaticResource StudioSubTabItem}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 추가" Command="{Binding AddInstanceCommand}"
                                            Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"/>
                                    <Button Content="✗ 삭제" Command="{Binding RemoveInstanceCommand}"
                                            Style="{StaticResource StudioDangerBtn}"/>
                                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                               Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11">
                                        <Run Text="총 "/>
                                        <Run Text="{Binding Instances.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" 개 인스턴스"/>
                                    </TextBlock>
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Instances}"
                                          SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Background="#1A2B3C" BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A4A7F"
                                          RowBackground="#1A2B3C" AlternatingRowBackground="#243447"
                                          ColumnHeaderStyle="{StaticResource StudioGridHeader}"
                                          CellStyle="{StaticResource StudioGridCell}"
                                          FontFamily="맑은 고딕" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="LocalName *" Width="220"
                                            Binding="{Binding LocalName, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="ClassOf (속한 클래스)" Width="220"
                                            Binding="{Binding ClassOf, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Label" Width="*"
                                            Binding="{Binding Label, UpdateSourceTrigger=LostFocus}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 서브탭 4: Triple -->
                        <TabItem Header="🔺 Triple" Style="{StaticResource StudioSubTabItem}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="+ 추가" Command="{Binding AddTripleCommand}"
                                            Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"/>
                                    <Button Content="✗ 삭제" Command="{Binding RemoveTripleCommand}"
                                            Style="{StaticResource StudioDangerBtn}"/>
                                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                               Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11"
                                               TextWrapping="Wrap">
                                        <Run Text="자유 진술 — Object 가 리터럴이면 'Literal?' 체크."/>
                                    </TextBlock>
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Triples}"
                                          SelectedItem="{Binding SelectedTriple, Mode=TwoWay}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Background="#1A2B3C" BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A4A7F"
                                          RowBackground="#1A2B3C" AlternatingRowBackground="#243447"
                                          ColumnHeaderStyle="{StaticResource StudioGridHeader}"
                                          CellStyle="{StaticResource StudioGridCell}"
                                          FontFamily="맑은 고딕" FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Subject *" Width="240"
                                            Binding="{Binding Subject, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Predicate *" Width="240"
                                            Binding="{Binding Predicate, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTextColumn Header="Object *" Width="*"
                                            Binding="{Binding ObjectValue, UpdateSourceTrigger=LostFocus}"/>
                                        <DataGridTemplateColumn Header="Literal?" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding ObjectIsLiteral, Mode=TwoWay}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 서브탭 5: SPARQL -->
                        <TabItem Header="🔍 SPARQL" Style="{StaticResource StudioSubTabItem}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource StudioLabel}"
                                           Margin="0,0,0,4" Foreground="#7DD8E8" FontWeight="SemiBold">
                                    🔍 SPARQL 쿼리 (PREFIX 자동 추가됨 — rdf, rdfs, owl, xsd, base prefix)
                                </TextBlock>
                                <TextBox Grid.Row="1" Style="{StaticResource StudioCodeBox}"
                                         Text="{Binding SparqlText, UpdateSourceTrigger=PropertyChanged}"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="▶  실행" Command="{Binding RunSparqlCommand}"
                                            Style="{StaticResource StudioPrimaryBtn}" Margin="0,0,6,0"
                                            Padding="20,6"/>
                                    <Button Content="✗  결과 지우기" Command="{Binding ClearSparqlCommand}"
                                            Style="{StaticResource StudioBtn}"/>
                                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                               Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11"
                                               Text="{Binding SparqlStatus}"/>
                                </StackPanel>
                                <Border Grid.Row="3" Height="1" Background="#2E75B6" Margin="0,8,0,0"/>
                                <DataGrid Grid.Row="4" Margin="0,8,0,0"
                                          ItemsSource="{Binding SparqlResultsView}"
                                          AutoGenerateColumns="True" IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          Background="#1A2B3C" BorderThickness="0"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#2A4A7F"
                                          RowBackground="#1A2B3C" AlternatingRowBackground="#243447"
                                          ColumnHeaderStyle="{StaticResource StudioGridHeader}"
                                          CellStyle="{StaticResource StudioGridCell}"
                                          FontFamily="Consolas" FontSize="12"/>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- 상태 메시지 -->
                    <Border Grid.Row="2" Background="#243447" CornerRadius="3"
                            Padding="10,6" Margin="0,10,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#9DB4CC" FontFamily="맑은 고딕" FontSize="11"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>
            <!-- ▲ TTL Studio 탭 끝 -->

        </TabControl>

        <!-- ── 상태 바 ── -->
        <Border Grid.Row="2" Background="#141D28" BorderBrush="#2A4A7F" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding DbPath, StringFormat='DB 경로: {0}'}"
                       Foreground="#5A7A9A" FontFamily="Consolas" FontSize="11"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>
    </Grid>
</Window>
