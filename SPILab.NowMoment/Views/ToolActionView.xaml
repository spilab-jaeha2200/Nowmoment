<!-- ════════════════════════════════════════════════════════════════════
     Views/ToolActionView.xaml — 통합 도구 액션 화면 공용 (SCR-D 그룹)

     사용처:
       • 📁 폴더 임포트  → v3 FolderImportCommand
       • 💾 DB 백업      → v3 BackupDbCommand
       • 📑 PDF 카탈로그 → v3 ExportPdfCatalogCommand

     구조:
       Row 0: 아이콘 + 제목 + 부제
       Row 1: 설명 단락
       Row 2: 항목 카드 (Bullets — 옵션/포함 항목 등)
       Row 3: 액션 버튼 (큰 PrimaryButton)
       Row 4: 마지막 실행 결과 (있다면)

     모든 색상 토큰: Theme.* (라이트/다크 자동 전환).
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.ToolActionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="맑은 고딕">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,20" MaxWidth="820" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ Row 0: 헤더 (아이콘 + 제목 + 부제) ════════ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="{Binding Icon}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Accent}"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Foreground="{DynamicResource Theme.FgMuted}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- ════════ Row 1: 설명 ════════ -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                    Padding="14,4,0,4"
                    Margin="0,12,0,16">
                <TextBlock Text="{Binding Description}"
                           Foreground="{DynamicResource Theme.FgPrimary}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="22"/>
            </Border>

            <!-- ════════ Row 2: 항목 카드 ════════ -->
            <Border Grid.Row="2"
                    Style="{StaticResource DetailCard}"
                    Padding="18,14"
                    Margin="0,0,0,18"
                    Visibility="{Binding HasBullets, Converter={StaticResource BoolToVisDlg}}">
                <ItemsControl ItemsSource="{Binding Bullets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="▸"
                                           Foreground="{DynamicResource Theme.Cyan}"
                                           FontSize="12" FontWeight="Bold"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding}"
                                           Foreground="{DynamicResource Theme.FgPrimary}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ════════ Row 3: 액션 버튼 ════════ -->
            <Button Grid.Row="3"
                    Content="{Binding ButtonLabel}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ActionCommand}"
                    HorizontalAlignment="Left"
                    Padding="28,12"
                    FontSize="14"
                    FontWeight="Bold"
                    Margin="0,0,0,16"/>

            <!-- ════════ Row 4: 결과 ════════ -->
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="3"
                    Padding="14,10"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisDlg}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Theme.BgCard}"/>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding LastResult}"
                           FontFamily="Consolas" FontSize="12"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Success}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResultError}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.Error}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
