<!-- ════════════════════════════════════════════════════════════════════
     Views/AuditLogView.xaml — 이력 / 변경 로그 화면 (audit_log read-only)

     라이트/다크 자동 대응: 모든 색상은 Theme.* 토큰 사용.
     공용 스타일(V4DataGrid / DetailCard / FilterCombo / PrimaryButton /
     SecondaryButton) 을 적용하여 다른 v4 화면과 톤을 통일.
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="Malgun Gothic">
    <Grid Margin="20,16,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── 타이틀 ─────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🕐  이력 / 변경 로그" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource Theme.Accent}"/>
            <TextBlock Text="(audit_log 테이블 read-only)" Margin="12,8,0,0"
                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="12"/>
        </StackPanel>

        <!-- ── 필터 툴바 ──────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource Theme.BgCard}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="자산:" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontWeight="Bold"
                           Foreground="{DynamicResource Theme.FgPrimary}"/>
                <ComboBox Grid.Column="1" Style="{StaticResource FilterCombo}"
                          Width="150" Margin="0,0,12,0"
                          ItemsSource="{Binding AssetTypeOptions}"
                          SelectedItem="{Binding SelectedAssetType}"/>

                <TextBlock Grid.Column="2" Text="액션:" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontWeight="Bold"
                           Foreground="{DynamicResource Theme.FgPrimary}"/>
                <ComboBox Grid.Column="3" Style="{StaticResource FilterCombo}"
                          Width="120" Margin="0,0,12,0"
                          ItemsSource="{Binding ActionOptions}"
                          SelectedItem="{Binding SelectedAction}"/>

                <DatePicker Grid.Column="4" SelectedDate="{Binding FromDate}"
                            Margin="0,0,6,0" Width="135"/>
                <TextBlock Grid.Column="5" Text="~" VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="{DynamicResource Theme.FgMuted}"/>
                <DatePicker Grid.Column="6" SelectedDate="{Binding ToDate}" Width="135"/>

                <Button Grid.Column="8" Content="🔄 조회"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" Margin="0,0,6,0"/>
                <Button Grid.Column="9" Content="📤 CSV"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportCsvCommand}"/>
            </Grid>
        </Border>

        <!-- ── 통계 카드 4종 ──────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,8,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="총 이벤트" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.FgMuted}"/>
                    <TextBlock Text="{Binding StatTotal}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.FgPrimary}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6" Margin="4,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="등록 (create)" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.FgMuted}"/>
                    <TextBlock Text="{Binding StatCreate}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Success}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6" Margin="4,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="수정 (update)" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.FgMuted}"/>
                    <TextBlock Text="{Binding StatUpdate}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Cyan}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6" Margin="8,0,0,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="삭제 (delete)" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.FgMuted}"/>
                    <TextBlock Text="{Binding StatDelete}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Error}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── 데이터그리드 + 우측 diff 패널 ───────────── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="4">
                <DataGrid Style="{StaticResource V4DataGrid}"
                          ItemsSource="{Binding Logs}"
                          SelectedItem="{Binding SelectedLog}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"        Binding="{Binding Id}"        Width="60"/>
                        <DataGridTextColumn Header="시각"      Binding="{Binding Ts}"        Width="160"/>
                        <DataGridTextColumn Header="사용자"    Binding="{Binding Actor}"     Width="90"/>
                        <DataGridTextColumn Header="액션"      Binding="{Binding Action}"    Width="80"/>
                        <DataGridTextColumn Header="자산 유형" Binding="{Binding AssetType}" Width="140"/>
                        <DataGridTextColumn Header="자산 ID"   Binding="{Binding AssetId}"   Width="80"/>
                        <DataGridTextColumn Header="변경 요약" Binding="{Binding DiffJson}"  Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{DynamicResource Theme.Accent}"
                            CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="📋  변경 내역 (diff_json)" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgOnAccent}"/>
                    </Border>
                    <Border Grid.Row="1" Background="{DynamicResource Theme.BgCard}"
                            CornerRadius="0,0,6,6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                            <TextBlock Text="{Binding SelectedDiffPretty}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgPrimary}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
