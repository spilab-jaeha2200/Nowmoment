<!-- ════════════════════════════════════════════════════════════════════
     KgEdgeEditDialog.xaml — KG 엣지 추가 (v2.7.3)

     v2.7.2 → v2.7.3 변경 (라이트/다크 테마 호환):
       • 하드코딩 다크색(#1A2332 등) + DarkInputs.xaml 의존 제거.
       • 모든 색상을 DynamicResource Theme.* 로 바인딩 → 테마 자동 추종.
       • EditDialogStyles.xaml 의 공유 스타일 사용 (헤더/푸터/입력박스).
       • 콤보박스 3종은 전용 템플릿 EdgeDlgComboTemplate 유지 — 편집형
         (IsEditable=True, 검색·직접입력) + v2.7.2 의 커서·드롭다운 너비
         수정을 보존하되 색상만 Theme.* 로 교체.
       • 코드비하인드(KgEdgeEditDialog.xaml.cs)는 변경 없음
         (x:Name·이벤트 시그니처 동일).
-->
<Window x:Class="SPILab.NowMoment.Views.KgEdgeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KG 엣지 추가" Height="560" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Theme.BgMain}"
        FontFamily="맑은 고딕"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Themes/EditDialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ════════════════════════════════════════════════════
                 이 다이얼로그 전용 편집형 ComboBox 템플릿 (테마 대응)
                 ════════════════════════════════════════════════════ -->
            <ControlTemplate x:Key="EdgeDlgComboTemplate" TargetType="ComboBox">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>

                    <!-- 입력 영역 배경 -->
                    <Border Grid.ColumnSpan="2" x:Name="OuterBd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="3"/>

                    <!-- 사용자 입력용 TextBox (커스텀 템플릿 없음 → 캐럿 정상) -->
                    <TextBox x:Name="PART_EditableTextBox"
                             Grid.Column="0" Margin="6,0,2,0"
                             Background="Transparent"
                             Foreground="{DynamicResource Theme.FgPrimary}"
                             CaretBrush="{DynamicResource Theme.FgPrimary}"
                             SelectionBrush="{DynamicResource Theme.Accent}"
                             BorderThickness="0" Padding="0"
                             FontFamily="맑은 고딕" FontSize="13"
                             IsReadOnly="{TemplateBinding IsReadOnly}"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Center"/>

                    <!-- 펼침 토글 -->
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  Background="Transparent" BorderThickness="0"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Grid Background="Transparent">
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{DynamicResource Theme.FgSecondary}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- 드롭다운 — 너비를 콤보박스에 맞춤 (PlacementTarget 기준) -->
                    <Popup x:Name="PART_Popup" Grid.ColumnSpan="2" Placement="Bottom"
                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                        <Border Background="{DynamicResource Theme.BgCard}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                CornerRadius="3"
                                Width="{Binding PlacementTarget.ActualWidth,
                                        RelativeSource={RelativeSource AncestorType=Popup}}"
                                MaxHeight="320">
                            <ScrollViewer SnapsToDevicePixels="True"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter TargetName="OuterBd" Property="BorderBrush"
                                Value="{DynamicResource Theme.Accent}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- 콤보박스 3종에 적용할 스타일 -->
            <Style x:Key="EdgeDlgCombo" TargetType="ComboBox">
                <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
                <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
                <Setter Property="FontFamily"      Value="맑은 고딕"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource DlgComboItem}"/>
                <Setter Property="Template"        Value="{StaticResource EdgeDlgComboTemplate}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- 외곽 1px 테두리 -->
    <Border BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>    <!-- 헤더 -->
                <RowDefinition Height="*"/>     <!-- 본문 -->
                <RowDefinition Height="Auto"/>  <!-- 푸터 -->
            </Grid.RowDefinitions>

            <!-- ══ 헤더 ══ -->
            <Border Grid.Row="0" Background="{DynamicResource Theme.BgDialogHeader}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="24,0,0,0">
                    <TextBlock Text="🔗" Foreground="White"
                               FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="KG 엣지 추가"
                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ══ 본문 ══ -->
            <Grid Grid.Row="1" Margin="28,22,28,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 시작 노드 -->
                    <RowDefinition Height="Auto"/>   <!-- 종료 노드 -->
                    <RowDefinition Height="Auto"/>   <!-- 관계 -->
                    <RowDefinition Height="Auto"/>   <!-- props 라벨 -->
                    <RowDefinition Height="*"/>      <!-- props 입력 -->
                    <RowDefinition Height="Auto"/>   <!-- 에러 -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 시작 노드 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="시작 노드 *"
                           Style="{StaticResource DlgFieldLabel}" Margin="0,0,12,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbSrc" Margin="0,6" Loaded="EditableCombo_Loaded"
                          MinHeight="34"
                          Style="{StaticResource EdgeDlgCombo}"
                          IsEditable="True" DisplayMemberPath="Display" SelectedValuePath="Id"
                          ToolTip="현재 도메인의 노드 목록 — 검색/직접 입력 가능"/>

                <!-- 종료 노드 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="종료 노드 *"
                           Style="{StaticResource DlgFieldLabel}" Margin="0,0,12,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CmbDst" Margin="0,6" Loaded="EditableCombo_Loaded"
                          MinHeight="34"
                          Style="{StaticResource EdgeDlgCombo}"
                          IsEditable="True" DisplayMemberPath="Display" SelectedValuePath="Id"/>

                <!-- 관계 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="관계(rel) *"
                           Style="{StaticResource DlgFieldLabel}" Margin="0,0,12,0"
                           ToolTip="USES / GOVERNS / DERIVES_FROM / CITES / BELONGS_TO / REQUIRES 등"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbRel" Margin="0,6" Loaded="EditableCombo_Loaded"
                          MinHeight="34"
                          Style="{StaticResource EdgeDlgCombo}"
                          IsEditable="True"/>

                <!-- props 라벨 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="속성 (props_json)"
                           Style="{StaticResource DlgFieldLabel}" Margin="0,10,0,4"/>

                <!-- props 입력 -->
                <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                         x:Name="TxtProps"
                         Style="{StaticResource DlgInputMultiline}"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         MinHeight="120"/>

                <!-- 에러 -->
                <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                           x:Name="TxtError"
                           Foreground="{DynamicResource Theme.Error}"
                           FontFamily="맑은 고딕" FontSize="12"
                           TextWrapping="Wrap" Margin="0,8,0,0"/>
            </Grid>

            <!-- ══ 푸터 ══ -->
            <Border Grid.Row="2" Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
                    Padding="28,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Margin="0,0,10,0" IsCancel="True"
                            Style="{StaticResource DlgFooterCancelBtn}"/>
                    <Button Content="추가" IsDefault="True"
                            Style="{StaticResource DlgFooterPrimaryBtn}"
                            Click="OkButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
