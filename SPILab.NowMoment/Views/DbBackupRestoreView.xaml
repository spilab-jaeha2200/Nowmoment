<!-- ════════════════════════════════════════════════════════════════════
     Views/DbBackupRestoreView.xaml — DB 백업 / 복원 화면 (SCR-D02)

     구성:
       ① 백업 섹션  — 활성. v3 BackupDbCommand 호출.
       ② 복원 섹션  — 비활성(준비 중). 버튼 IsEnabled=False 로 표시만.

     모든 색상은 Theme.* 토큰 → 라이트/다크 자동 전환.
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.DbBackupRestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="맑은 고딕">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,20" MaxWidth="860" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════
                 ① 백업 섹션 (활성)
                 ════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">

                <!-- 헤더 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="💾" FontSize="30" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DB 백업"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Accent}"/>
                        <TextBlock Text="SQLite BACKUP API + manifest.json 으로 안전한 .zip 백업을 생성합니다."
                                   Foreground="{DynamicResource Theme.FgMuted}"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 설명 -->
                <Border BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                        Padding="14,4,0,4" Margin="0,12,0,16">
                    <TextBlock Foreground="{DynamicResource Theme.FgPrimary}"
                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                               Text="SqliteConnection.BackupDatabase() 를 사용하여 DB 잠금 상태와 무관하게 일관된 스냅샷을 만들고, manifest.json (자산 카운트 + SHA-256 해시) 과 함께 .zip 으로 패키징합니다. 저장 위치는 다이얼로그로 선택합니다."/>
                </Border>

                <!-- 항목 카드 -->
                <Border Style="{StaticResource DetailCard}" Padding="18,14" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="▸  SqliteConnection.BackupDatabase() — 일관된 스냅샷"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  manifest.json 포함 — 자산 카운트 + SHA-256 무결성 검증"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  기본 파일명: NowMoment_DB_yyyyMMdd_HHmmss.zip"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  백업 완료 후 결과 다이얼로그에서 백업 통계 확인"
                                   Foreground="{DynamicResource Theme.FgPrimary}" FontSize="12" Margin="0,3"/>
                    </StackPanel>
                </Border>

                <!-- 백업 버튼 -->
                <Button Content="▶  백업 위치 선택 후 시작"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BackupCommand}"
                        HorizontalAlignment="Left"
                        Padding="28,12" FontSize="14" FontWeight="Bold"
                        Margin="0,0,0,10"/>

                <!-- 백업 결과 -->
                <Border BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                        CornerRadius="3" Padding="14,10"
                        Background="{DynamicResource Theme.BgCard}"
                        Visibility="{Binding HasBackupResult, Converter={StaticResource BoolToVisDlg}}">
                    <TextBlock Text="{Binding BackupResult}"
                               FontFamily="Consolas" FontSize="12" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Theme.Success}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackupError}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Theme.Error}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════
                 ② 복원 섹션 (비활성 — 준비 중)
                 ════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1">

                <!-- 헤더 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="♻" FontSize="30" VerticalAlignment="Center" Margin="0,0,12,0"
                               Foreground="{DynamicResource Theme.FgMuted}"/>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DB 복원"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <Border Background="{DynamicResource Theme.BgDisabled}"
                                    CornerRadius="3" Padding="8,2" Margin="10,2,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="준비 중"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource Theme.FgSecondary}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="백업 .zip 파일로부터 데이터베이스를 복원합니다. (다음 버전에서 제공 예정)"
                                   Foreground="{DynamicResource Theme.FgMuted}"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 설명 -->
                <Border BorderBrush="{DynamicResource Theme.Border}" BorderThickness="3,0,0,0"
                        Padding="14,4,0,4" Margin="0,12,0,16">
                    <TextBlock Foreground="{DynamicResource Theme.FgMuted}"
                               FontSize="13" TextWrapping="Wrap" LineHeight="22"
                               Text="백업 .zip 의 manifest.json 을 검증한 뒤 현재 데이터베이스를 백업 시점 상태로 되돌립니다. 복원 전 현재 DB 는 자동으로 안전 백업되며, SHA-256 해시 불일치 시 복원이 중단됩니다."/>
                </Border>

                <!-- 항목 카드 (비활성 톤) -->
                <Border BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                        CornerRadius="6" Padding="18,14" Margin="0,0,0,18"
                        Background="{DynamicResource Theme.BgGridRowOdd}">
                    <StackPanel>
                        <TextBlock Text="▸  백업 .zip 선택 → manifest.json 무결성 검증"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  복원 전 현재 DB 자동 안전 백업 (롤백 지점 생성)"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  SHA-256 해시 불일치 시 복원 중단"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12" Margin="0,3"/>
                        <TextBlock Text="▸  복원 완료 후 애플리케이션 재시작 안내"
                                   Foreground="{DynamicResource Theme.FgMuted}" FontSize="12" Margin="0,3"/>
                    </StackPanel>
                </Border>

                <!-- 복원 버튼 (비활성) -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="▶  복원할 백업 파일 선택"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            HorizontalAlignment="Left"
                            Padding="28,12" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="다음 버전에서 제공될 예정입니다."
                               Foreground="{DynamicResource Theme.FgMuted}"
                               FontSize="11" VerticalAlignment="Center"
                               Margin="14,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
