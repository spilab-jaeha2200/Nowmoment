<!-- ════════════════════════════════════════════════════════════════════
     Views/ProjectTagView.xaml — 프로젝트 · 태그 관리 화면 (SCR-A06)

     라이트/다크 자동 대응: 모든 색상은 Theme.* 토큰 사용.
     좌측: 프로젝트 목록 + CRUD / 우측: 자산 통계 카드 5종 + 상위 태그.
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.ProjectTagView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="Malgun Gothic">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="20,16,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="📁  프로젝트 · 태그 관리" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource Theme.Accent}"/>
            <TextBlock Text="(프로젝트 CRUD + 자산 통계 + 태그 빈도)" Margin="12,8,0,0"
                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="12"/>
        </StackPanel>

        <!-- 툴바 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="＋ 프로젝트" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddCommand}" Margin="0,0,6,0"/>
            <Button Content="✎ 이름 수정" Style="{StaticResource SecondaryButton}"
                    Command="{Binding EditCommand}" Margin="0,0,6,0"/>
            <Button Content="✗ 삭제" Style="{StaticResource SecondaryButton}"
                    Command="{Binding DeleteCommand}" Margin="0,0,6,0"/>
            <Button Content="🔄 새로고침" Style="{StaticResource SecondaryButton}"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <!-- 본문: 좌측 트리 + 우측 통계 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 프로젝트 트리 -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource Theme.Accent}"
                            CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="📂  프로젝트 목록" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgOnAccent}"/>
                    </Border>
                    <Border Grid.Row="1" Background="{DynamicResource Theme.BgCard}"
                            CornerRadius="0,0,6,6">
                        <ListBox BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding Projects}"
                                 SelectedItem="{Binding SelectedProject}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.BgSelected}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Theme.BgHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                   Foreground="{DynamicResource Theme.FgPrimary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Client}"
                                                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="10"/>
                                            <TextBlock Text="  ·  "
                                                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="10"/>
                                            <TextBlock Text="{Binding Type}"
                                                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="10"/>
                                            <TextBlock Text="  ·  "
                                                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="10"/>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="{DynamicResource Theme.FgMuted}" FontSize="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>

            <!-- 우측 패널 -->
            <Grid Grid.Column="1" Margin="14,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 선택 프로젝트 헤더 -->
                <TextBlock Grid.Row="0" Text="{Binding SelectedHeader}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Theme.Accent}" Margin="0,0,0,12"/>

                <!-- 자산 통계 카드 5종 -->
                <Grid Grid.Row="1" Margin="0,0,0,14"
                      Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Theme.BgCard}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="소스코드" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <TextBlock Text="{Binding StatCode}" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Background="{DynamicResource Theme.BgCard}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="AI 모델" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <TextBlock Text="{Binding StatModel}" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Background="{DynamicResource Theme.BgCard}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="문서" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <TextBlock Text="{Binding StatDoc}" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3"
                            Background="{DynamicResource Theme.BgCard}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="특허" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <TextBlock Text="{Binding StatPatent}" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4"
                            Background="{DynamicResource Theme.BgCard}"
                            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="14,12" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="실험" FontSize="11"
                                       Foreground="{DynamicResource Theme.FgMuted}"/>
                            <TextBlock Text="{Binding StatExp}" FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 합계 요약 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource Theme.BgCard}"
                        BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,14"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📌  총 자산 수: " FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Accent}"/>
                        <TextBlock Text="{Binding StatTotal}" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Accent}" FontSize="14"/>
                        <TextBlock Text="개" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Accent}"/>
                    </StackPanel>
                </Border>

                <!-- 상위 태그 -->
                <Border Grid.Row="3"
                        BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource Theme.Accent}"
                                CornerRadius="6,6,0,0" Padding="12,8">
                            <TextBlock Text="🏷  상위 태그 (소스코드 기준 빈도순)" FontWeight="Bold"
                                       Foreground="{DynamicResource Theme.FgOnAccent}"/>
                        </Border>
                        <Border Grid.Row="1" Background="{DynamicResource Theme.BgCard}"
                                CornerRadius="0,0,6,6">
                            <ItemsControl ItemsSource="{Binding TopTags}" Padding="14">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding Count, Mode=OneWay}"
                                                         Maximum="20" Height="14"
                                                         Foreground="{DynamicResource Theme.Accent}"
                                                         Background="{DynamicResource Theme.BgDisabled}"
                                                         BorderBrush="{DynamicResource Theme.Border}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                       HorizontalAlignment="Right" FontWeight="Bold"
                                                       Foreground="{DynamicResource Theme.FgPrimary}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
