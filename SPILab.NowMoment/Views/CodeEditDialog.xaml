<!-- ════════════════════════════════════════════════════════════
     CodeEditDialog.xaml — v4 Phase 6 (라이트 테마, 화면설계서 §4.3 + §5.1)

     2-컬럼 그리드:
       Row 0: 자산명*       | 언어/유형
       Row 1: 프로젝트*     | 버전
       Row 2: 저장소 URL  (full)
       Row 3: 태그        (full)
       Row 4: 설명        (full, 4행 멀티라인)

     푸터: [취소]  [저장]  [저장+계속]
     ════════════════════════════════════════════════════════════ -->
<Window x:Class="SPILab.NowMoment.Views.CodeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SPILab.NowMoment.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="자산 등록 — 소스코드 / 모듈"
        Width="920" Height="700"
        MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Theme.BgMain}"
        FontFamily="맑은 고딕"
        WindowStyle="None"
        AllowsTransparency="False">
    <!-- WindowChrome: WindowStyle=None 시 상단에 남는 시스템 흰 테두리 제거 -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1,0,1,1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>    <!-- 헤더 -->
                <RowDefinition Height="Auto"/>  <!-- 본문 (기본 정보) - 내용 높이만 -->
                <RowDefinition Height="Auto"/>  <!-- 푸터 - 본문 바로 아래 밀착 -->
                <RowDefinition Height="*"/>     <!-- KG 노드 연결 패널 (남는 공간) -->
            </Grid.RowDefinitions>

            <!-- ══ 1. 헤더 (네이비, 드래그 이동) ════════════════════ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Theme.BgDialogHeader}"
                    MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="✎" Foreground="White"
                                   FontSize="16" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="HeaderTitle"
                                   Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="자산 등록 — 소스코드 / 모듈"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕"
                            Style="{StaticResource DlgCloseXBtn}"
                            Margin="0,0,10,0"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ══ 2. 본문 ═══════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource Theme.BgMain}">
                <Grid Margin="28,22,28,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 기본 정보 헤더 -->
                        <RowDefinition Height="Auto"/>  <!-- 기본 정보 그리드 -->
                    </Grid.RowDefinitions>

                    <!-- ── 섹션 헤더 ─────────────────────────────── -->
                    <TextBlock Grid.Row="0" Style="{StaticResource DlgSectionHeader}">
                        <Run Text="■"/>
                        <Run Text=" 기본 정보"/>
                    </TextBlock>

                    <!-- ── 기본 정보 그리드 ─────────────────────── -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>  <!-- 라벨 1 -->
                            <ColumnDefinition Width="*"/>     <!-- 값 1   -->
                            <ColumnDefinition Width="24"/>    <!-- 갭     -->
                            <ColumnDefinition Width="100"/>  <!-- 라벨 2 -->
                            <ColumnDefinition Width="*"/>     <!-- 값 2   -->
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>   <!-- 자산명 / 언어    -->
                            <RowDefinition Height="44"/>   <!-- 프로젝트 / 버전  -->
                            <RowDefinition Height="44"/>   <!-- 저장소 URL       -->
                            <RowDefinition Height="44"/>   <!-- 태그             -->
                            <RowDefinition Height="Auto"/> <!-- 설명             -->
                        </Grid.RowDefinitions>

                        <!-- Row 0: 자산명* | 언어/유형 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DlgFieldLabel}">
                            <Run Text="자산명"/>
                            <Run Text=" *" Foreground="{DynamicResource Theme.Error}"/>
                        </TextBlock>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource DlgInputBox}"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource DlgFieldLabel}"
                                   Text="언어/유형"/>
                        <ComboBox Grid.Row="0" Grid.Column="4"
                                  Style="{StaticResource DlgInputCombo}"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding Language}"
                                  VerticalAlignment="Center"/>

                        <!-- Row 1: 프로젝트* | 버전 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DlgFieldLabel}">
                            <Run Text="프로젝트"/>
                            <Run Text=" *" Foreground="{DynamicResource Theme.Error}"/>
                        </TextBlock>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  Style="{StaticResource DlgInputCombo}"
                                  ItemsSource="{Binding Projects}"
                                  SelectedItem="{Binding SelectedProject}"
                                  DisplayMemberPath="Name"
                                  VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource DlgFieldLabel}"
                                   Text="버전"/>
                        <TextBox Grid.Row="1" Grid.Column="4"
                                 Style="{StaticResource DlgInputBox}"
                                 Text="{Binding Version}"
                                 VerticalAlignment="Center"/>

                        <!-- Row 2: 저장소 URL (전체 폭) -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DlgFieldLabel}"
                                   Text="저장소 URL"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                                 Style="{StaticResource DlgInputBox}"
                                 Text="{Binding RepoUrl}"
                                 VerticalAlignment="Center"/>

                        <!-- Row 3: 태그 (전체 폭) -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DlgFieldLabel}"
                                   Text="태그"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4"
                                 Style="{StaticResource DlgInputBox}"
                                 Text="{Binding Tags}"
                                 VerticalAlignment="Center"
                                 ToolTip="콤마(,)로 구분"/>

                        <!-- Row 4: 설명 (전체 폭, 멀티라인) -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DlgFieldLabel}"
                                   Text="설명"
                                   VerticalAlignment="Top" Margin="0,10,12,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                                 Style="{StaticResource DlgInputMultiline}"
                                 Text="{Binding Description}"
                                 Margin="0,6,0,0"/>
                    </Grid>

                    <!-- ── KG 노드 연결 패널 ────────────────────── -->
                </Grid>
            </ScrollViewer>

            <!-- ══ KG 노드 연결 패널 (푸터보다 아래, 다이얼로그 맨 아래) ══ -->
            <Border Grid.Row="3"
                    Background="{DynamicResource Theme.BgCard}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="24,14,24,18">
                <local:AssetKgLinkPanelView DataContext="{Binding KgPanel}"
                                            MinHeight="220"/>
            </Border>

            <!-- ══ 3. 푸터 ═══════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="{DynamicResource Theme.BgMain}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소"
                            Style="{StaticResource DlgFooterCancelBtn}"
                            IsCancel="True"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click"/>
                    <Button Content="저장"
                            Style="{StaticResource DlgFooterPrimaryBtn}"
                            IsDefault="True"
                            Margin="0,0,8,0"
                            Click="SaveButton_Click"/>
                    <Button Content="저장+계속"
                            Style="{StaticResource DlgFooterSecondaryBtn}"
                            Click="SaveAndContinueButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
