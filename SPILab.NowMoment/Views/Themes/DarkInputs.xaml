<!-- ════════════════════════════════════════════════════════════════════
     Views/Themes/DarkInputs.xaml — KG 다이얼로그 공통 다크 테마 리소스 (v2.7)

     역할:
       Window 별로 ComboBox / TextBox / RadioButton / CheckBox 스타일을
       흩어져 정의하던 것을 한 곳으로 모은다. 이렇게 하면:
       (1) IsEditable=true 인 ComboBox 의 입력부가 흰 배경으로 보이는 문제 해결
       (2) 드롭다운 열렸을 때 항목 색상 일관 유지
       (3) 비활성(IsEnabled=False) 상태에서도 가독성 보장

     사용:
       <Window.Resources>
           <ResourceDictionary>
               <ResourceDictionary.MergedDictionaries>
                   <ResourceDictionary Source="/Views/Themes/DarkInputs.xaml"/>
               </ResourceDictionary.MergedDictionaries>
           </ResourceDictionary>
       </Window.Resources>

     색상 토큰 (NowMoment 다크 테마와 일치):
       배경: #1A2B3C (입력 활성), #0E1722 (입력 비활성/강조 영역)
       테두리: #2E75B6 (기본), #5BA3D9 (포커스/선택)
       전경: #F0F4F8 (텍스트), #9DB4CC (라벨), #5F5E5A (placeholder)
       강조: #2A4A7F (호버), #2E75B6 (선택)
     ════════════════════════════════════════════════════════════════════ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── 색상 상수 ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="DarkInputBg"        Color="#1A2B3C"/>
    <SolidColorBrush x:Key="DarkInputBgStrong"  Color="#0E1722"/>
    <SolidColorBrush x:Key="DarkInputFg"        Color="#F0F4F8"/>
    <SolidColorBrush x:Key="DarkInputFgMuted"   Color="#9DB4CC"/>
    <SolidColorBrush x:Key="DarkInputFgPlaceholder" Color="#5F5E5A"/>
    <SolidColorBrush x:Key="DarkInputBorder"    Color="#2E75B6"/>
    <SolidColorBrush x:Key="DarkInputBorderFocus" Color="#5BA3D9"/>
    <SolidColorBrush x:Key="DarkInputHover"     Color="#2A4A7F"/>
    <SolidColorBrush x:Key="DarkInputSelected"  Color="#2E75B6"/>
    <SolidColorBrush x:Key="DarkInputDisabled"  Color="#243447"/>

    <!-- ════════════════════════════════════════════════════════
         Label
         ════════════════════════════════════════════════════════ -->
    <Style TargetType="Label" x:Key="DarkLabel">
        <Setter Property="Foreground" Value="{StaticResource DarkInputFgMuted}"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 암묵적 적용 -->
    <Style TargetType="Label" BasedOn="{StaticResource DarkLabel}"/>

    <!-- ════════════════════════════════════════════════════════
         TextBox — 일반 + 비활성 상태도 가독성 보장
         ════════════════════════════════════════════════════════ -->
    <Style TargetType="TextBox" x:Key="DarkTextBox">
        <Setter Property="Background" Value="{StaticResource DarkInputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DarkInputFg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DarkInputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <!-- ★ v2.7.11: 좌우 패딩만 유지, 상하는 0 으로 (수직 정렬은 ScrollViewer 가 담당) -->
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="SelectionBrush" Value="{StaticResource DarkInputSelected}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <!-- ★ v2.7.11: ScrollViewer 가 부모 Border 의 전체 높이를 차지하고
                             텍스트 콘텐츠를 수직 가운데 정렬. Padding 은 좌우만 적용. -->
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalAlignment="Stretch"
                                      VerticalContentAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Focusable="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource DarkInputBorderFocus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource DarkInputDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource DarkInputFgMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}"/>

    <!-- ════════════════════════════════════════════════════════
         ComboBox — 핵심 수정 대상
         (1) 닫힌 상태의 SelectionBox
         (2) 펼친 Popup 의 아이템들
         (3) IsEditable=True 인 경우 PART_EditableTextBox
         세 곳 모두 다크 테마 적용
         ════════════════════════════════════════════════════════ -->

    <!-- ComboBoxItem (Popup 안의 행) -->
    <Style TargetType="ComboBoxItem" x:Key="DarkComboBoxItem">
        <Setter Property="Background" Value="{StaticResource DarkInputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DarkInputFg}"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            TextElement.FontFamily="맑은 고딕"
                            TextElement.FontSize="13"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource DarkInputHover}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource DarkInputSelected}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboBoxItem}"/>

    <!-- 토글 버튼 (ComboBox 펼침 화살표) — 화살표만 다시 그리고 배경은 ComboBox 가 처리 -->
    <ControlTemplate x:Key="DarkComboBoxToggleTemplate" TargetType="ToggleButton">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2"
                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                    BorderThickness="1" CornerRadius="0"/>
            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                  Fill="{StaticResource DarkInputFgMuted}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </ControlTemplate>

    <!-- 비편집 ComboBox 템플릿 (IsEditable=False) -->
    <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
        <Grid>
            <ToggleButton Focusable="False" ClickMode="Press"
                          Template="{StaticResource DarkComboBoxToggleTemplate}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"/>
            <ContentPresenter Margin="8,6,28,6"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              TextElement.Foreground="{StaticResource DarkInputFg}"
                              TextElement.FontFamily="맑은 고딕"
                              TextElement.FontSize="13"
                              IsHitTestVisible="False"/>
            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                <Border Background="{StaticResource DarkInputBg}"
                        BorderBrush="{StaticResource DarkInputBorder}" BorderThickness="1"
                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="320">
                    <ScrollViewer SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
    </ControlTemplate>

    <!-- 편집 가능 ComboBox 템플릿 (IsEditable=True) — 핵심 수정 -->
    <ControlTemplate x:Key="DarkComboBoxEditableTemplate" TargetType="ComboBox">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
            </Grid.ColumnDefinitions>

            <!-- 입력 영역 배경 (다크) -->
            <Border Grid.ColumnSpan="2" x:Name="OuterBd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"/>

            <!-- 사용자 입력용 TextBox (이게 흰 배경으로 보이던 원흉) -->
            <!-- ★ v2.7.11: ScrollViewer 의 VerticalContentAlignment 명시로 텍스트 가운데 정렬 -->
            <TextBox x:Name="PART_EditableTextBox"
                     Grid.Column="0" Margin="8,0,4,0"
                     Background="Transparent"
                     Foreground="{StaticResource DarkInputFg}"
                     CaretBrush="White"
                     SelectionBrush="{StaticResource DarkInputSelected}"
                     BorderThickness="0"
                     FontFamily="맑은 고딕" FontSize="13"
                     IsReadOnly="{TemplateBinding IsReadOnly}"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Center">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Stretch"
                                      VerticalContentAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Focusable="False"
                                      Background="Transparent"/>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 펼침 토글 -->
            <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                          Background="Transparent" BorderThickness="0"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{StaticResource DarkInputFgMuted}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <!-- 드롭다운 -->
            <Popup Grid.ColumnSpan="2" Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                <Border Background="{StaticResource DarkInputBg}"
                        BorderBrush="{StaticResource DarkInputBorder}" BorderThickness="1"
                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="320">
                    <ScrollViewer SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="OuterBd" Property="BorderBrush"
                        Value="{StaticResource DarkInputBorderFocus}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ComboBox 본체 스타일 — IsEditable 에 따라 템플릿 자동 전환 -->
    <Style TargetType="ComboBox" x:Key="DarkComboBox">
        <Setter Property="Background" Value="{StaticResource DarkInputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DarkInputFg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DarkInputBorder}"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
        <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsEditable" Value="True">
                <Setter Property="Template" Value="{StaticResource DarkComboBoxEditableTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}"/>

    <!-- ════════════════════════════════════════════════════════
         RadioButton — 도메인 다이얼로그용
         ════════════════════════════════════════════════════════ -->
    <Style TargetType="RadioButton" x:Key="DarkRadioButton">
        <Setter Property="Foreground" Value="{StaticResource DarkInputFg}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,2,16,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse x:Name="Outer" Width="14" Height="14"
                                     Stroke="{StaticResource DarkInputBorder}" StrokeThickness="1.5"
                                     Fill="Transparent"/>
                            <Ellipse x:Name="Inner" Width="7" Height="7"
                                     Fill="{StaticResource DarkInputBorder}"
                                     Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontFamily="맑은 고딕"
                                          TextElement.FontSize="12"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Outer" Property="Stroke"
                                    Value="{StaticResource DarkInputBorderFocus}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Stroke"
                                    Value="{StaticResource DarkInputBorderFocus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource DarkInputFgMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="RadioButton" BasedOn="{StaticResource DarkRadioButton}"/>

    <!-- ════════════════════════════════════════════════════════
         Button — 다이얼로그 OK/Cancel 표준화
         ════════════════════════════════════════════════════════ -->
    <Style TargetType="Button" x:Key="DarkPrimaryBtn">
        <Setter Property="Background" Value="{StaticResource DarkInputSelected}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="맑은 고딕"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="0,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#5BA3D9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="DarkSecondaryBtn" BasedOn="{StaticResource DarkPrimaryBtn}">
        <Setter Property="Background" Value="#2A4A7F"/>
    </Style>
</ResourceDictionary>
