<!-- ════════════════════════════════════════════════════════════════════
     KgGraphView.xaml (v2.5)

     KG 노드/엣지를 Canvas 위에 force-directed 레이아웃으로 시각화.

     의존성:
       * KgViewModel.Nodes / Edges (ObservableCollection)
       * KgViewModel.SelectedNode (선택 시 강조)

     사용법:
       <local:KgGraphView DataContext="{Binding Kg}" />
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.KgGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgCard}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 그래프 컨트롤 바 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
            <Button x:Name="BtnRelayout" Content="재배치"
                    Padding="8,4" Margin="0,0,8,0"
                    Background="{DynamicResource Theme.Accent}" Foreground="{DynamicResource Theme.FgOnAccent}" BorderThickness="0"
                    FontFamily="맑은 고딕" FontSize="12"
                    Click="BtnRelayout_Click"/>
            <Button x:Name="BtnFit" Content="화면 맞춤"
                    Padding="8,4" Margin="0,0,12,0"
                    Background="Transparent" Foreground="{DynamicResource Theme.FgSecondary}"
                    BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="1"
                    FontFamily="맑은 고딕" FontSize="12"
                    Click="BtnFit_Click"/>

            <TextBlock Text="줌:" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       Margin="0,0,4,0" FontFamily="맑은 고딕" FontSize="12"/>
            <TextBlock x:Name="TxtZoom" Text="100%" Foreground="{DynamicResource Theme.FgPrimary}"
                       VerticalAlignment="Center" MinWidth="40"
                       FontFamily="Consolas" FontSize="12"/>

            <TextBlock Text="    범례:" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       Margin="20,0,4,0" FontFamily="맑은 고딕" FontSize="12"/>
            <Ellipse Width="10" Height="10" Fill="#E85577" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Text="PhysicsRule" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       FontFamily="맑은 고딕" FontSize="11" Margin="0,0,8,0"/>
            <Ellipse Width="10" Height="10" Fill="#2EA4C7" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Text="Material" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       FontFamily="맑은 고딕" FontSize="11" Margin="0,0,8,0"/>
            <Ellipse Width="10" Height="10" Fill="#4CAF72" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Text="Workspace" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       FontFamily="맑은 고딕" FontSize="11" Margin="0,0,8,0"/>
            <Ellipse Width="10" Height="10" Fill="#E8A838" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Text="Parameter" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       FontFamily="맑은 고딕" FontSize="11" Margin="0,0,8,0"/>
            <Ellipse Width="10" Height="10" Fill="#8B6FBF" VerticalAlignment="Center" Margin="4,0,2,0"/>
            <TextBlock Text="Spec" Foreground="{DynamicResource Theme.FgSecondary}" VerticalAlignment="Center"
                       FontFamily="맑은 고딕" FontSize="11" Margin="0,0,8,0"/>

            <TextBlock x:Name="TxtStatus" Text="" Foreground="{DynamicResource Theme.Accent}" VerticalAlignment="Center"
                       Margin="20,0,0,0" FontFamily="맑은 고딕" FontSize="11"/>
        </StackPanel>

        <!-- 그래프 캔버스 (스크롤/줌/팬 컨테이너) -->
        <Border Grid.Row="1" Background="{DynamicResource Theme.BgCard}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" Margin="8,4,8,8">
            <Grid ClipToBounds="True">
                <!-- 캔버스: RenderTransform 으로 줌/팬 처리 -->
                <Canvas x:Name="GraphCanvas"
                        Background="Transparent"
                        Width="2000" Height="1500"
                        MouseWheel="Canvas_MouseWheel"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="GraphScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="GraphPan" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</UserControl>
