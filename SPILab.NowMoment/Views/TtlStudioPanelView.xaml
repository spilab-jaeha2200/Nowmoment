<!-- ════════════════════════════════════════════════════════════════════
     Views/TtlStudioPanelView.xaml — TTL Studio 화면 (SCR-B06)

     구조 (Image 1 1:1):
       Row 0: 상단 툴바 (열기 / 저장 / 가져오기 / 내보내기 | 자동저장 라벨 | 동기화 상태)
       Row 1: 본문 (좌:Prefixes/Classes 카드 + 우:SPARQL 다크 에디터)
       Row 2: SPARQL 결과 카드 (헤더 + DataGrid + CSV/JSON/복사)

     모든 동작은 TtlStudioPanelViewModel 이 v3 TtlStudioViewModel 명령을
     그대로 패스스루.
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.TtlStudioPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Theme.BgMain}"
             FontFamily="맑은 고딕">

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: 상단 툴바 -->
            <RowDefinition Height="Auto"/>  <!-- 1: 좌 Prefixes/Classes  +  우 SPARQL 에디터 -->
            <RowDefinition Height="*"/>     <!-- 2: SPARQL 결과 -->
        </Grid.RowDefinitions>

        <!-- ════════ Row 0: 상단 툴바 ════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- 열기 -->
                <ColumnDefinition Width="Auto"/>  <!-- 저장 -->
                <ColumnDefinition Width="Auto"/>  <!-- 가져오기 -->
                <ColumnDefinition Width="Auto"/>  <!-- 내보내기 -->
                <ColumnDefinition Width="*"/>     <!-- spacer -->
                <ColumnDefinition Width="Auto"/>  <!-- 자동저장 -->
                <ColumnDefinition Width="Auto"/>  <!-- 동기화 상태 -->
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="📂 열기"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenFileCommand}"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="💾 저장"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveFileCommand}"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="📥 가져오기"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenFileCommand}"
                    ToolTip="기존 TTL 파일 가져오기 (열기와 동일)"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="📤 내보내기"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding SaveAsCommand}"
                    ToolTip="다른 이름으로 TTL 저장"
                    Margin="0,0,8,0"/>

            <!-- 자동저장 라벨 -->
            <TextBlock Grid.Column="5" Text="{Binding AutosaveLabel}"
                       Foreground="{DynamicResource Theme.Success}"
                       FontSize="12" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,18,0"/>

            <!-- 동기화 상태 -->
            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8"
                         Fill="{DynamicResource Theme.Success}"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SyncStatusText}"
                           Foreground="{DynamicResource Theme.FgMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ════════ Row 1: 좌 카드 + 우 SPARQL 에디터 ════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: Prefixes / Classes 카드 -->
            <Border Grid.Column="0" Style="{StaticResource DetailCard}" Padding="14,12">
                <StackPanel>
                    <!-- Prefixes 헤더 -->
                    <Border BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                            Padding="10,0,0,0" Margin="0,0,0,8">
                        <TextBlock Text="{Binding PrefixesHeader}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgPrimary}"/>
                    </Border>

                    <!-- prefix 목록 -->
                    <ItemsControl ItemsSource="{Binding Prefixes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource Theme.Accent}"
                                               Text="{Binding Prefix, StringFormat='{}{0}:'}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Iri}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource Theme.FgPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Classes / ObjectProperty 폴더 표시 -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{DynamicResource Theme.BgSidebar}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                CornerRadius="3" Padding="10,6" Margin="0,0,4,0">
                            <TextBlock Text="{Binding ClassesHeader}"
                                       Foreground="{DynamicResource Theme.FgPrimary}"
                                       FontSize="12"/>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{DynamicResource Theme.BgSidebar}"
                                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                                CornerRadius="3" Padding="10,6" Margin="4,0,0,0">
                            <TextBlock Text="{Binding PropertiesHeader}"
                                       Foreground="{DynamicResource Theme.FgPrimary}"
                                       FontSize="12"/>
                        </Border>
                    </Grid>

                    <!-- 전체 트리 보기 -->
                    <Button Content="🔍 전체 트리 보기"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowTreeCommand}"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- 우측: SPARQL 다크 에디터 -->
            <Border Grid.Column="2"
                    Background="#0E1722"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Grid Grid.Row="0" Background="#10202E">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                BorderBrush="#5BA3D9" BorderThickness="3,0,0,0"
                                Padding="10,8">
                            <TextBlock Text="SPARQL 쿼리"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#F0F4F8"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="1" Content="▶ 실행"
                                Background="#1F3864" Foreground="White"
                                BorderThickness="0" Padding="14,5"
                                FontWeight="Bold"
                                Margin="0,6,6,6"
                                Cursor="Hand"
                                Command="{Binding RunSparqlCommand}"/>
                        <Button Grid.Column="2" Content="💾 저장"
                                Background="#1A2B3C" Foreground="#F0F4F8"
                                BorderBrush="#2A3F58" BorderThickness="1"
                                Padding="14,5"
                                Margin="0,6,10,6"
                                Cursor="Hand"
                                Command="{Binding SaveSparqlCommand}"
                                ToolTip="현재 SPARQL 쿼리를 .rq 파일로 저장"/>
                    </Grid>

                    <!-- SPARQL 텍스트 영역 -->
                    <TextBox Grid.Row="1"
                             Text="{Binding SparqlText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="#F0F4F8"
                             BorderThickness="0"
                             CaretBrush="#F0F4F8"
                             FontFamily="Consolas" FontSize="13"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Padding="14,10"
                             MinHeight="180"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════ Row 2: SPARQL 결과 카드 ════════ -->
        <Border Grid.Row="2" Style="{StaticResource DetailCard}" Padding="14,12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 헤더 + 액션 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource Theme.Accent}" BorderThickness="3,0,0,0"
                            Padding="10,0,0,0">
                        <TextBlock Text="{Binding SparqlResultsHeader}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.FgPrimary}"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" Content="📤 CSV"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportCsvCommand}"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="2" Content="📤 JSON"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportJsonCommand}"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="3" Content="📋"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CopyResultsCommand}"
                            ToolTip="결과를 클립보드에 복사 (TSV)"/>
                </Grid>

                <!-- 결과 DataGrid (v3 TtlStudioViewModel.SparqlResultsView 는 DataView) -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                        CornerRadius="4">
                    <DataGrid Style="{StaticResource V4DataGrid}"
                              ItemsSource="{Binding SparqlResultsView}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                </Border>

                <!-- 상태 라벨 -->
                <TextBlock Grid.Row="2"
                           Text="{Binding SparqlStatus}"
                           Foreground="{DynamicResource Theme.FgMuted}"
                           FontSize="11"
                           Margin="4,8,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
