<!-- ════════════════════════════════════════════════════════════════════
     Views/SettingsDialog.xaml — v4 Phase 8

     좌측 카테고리 ListBox + 우측 카테고리별 설정 패널 (8개).
     모든 색은 DynamicResource Theme.* 사용 → 라이트/다크 자동 전환.

     좌측 8 카테고리:
        🎨 일반 / 🐍 Python / 🕸 KG 빌더 / 💾 DB
        🔒 보안 / 📤 내보내기 / 🌐 네트워크 / ℹ 정보

     우측: SelectedCategoryKey 값(general/python/kg/db/security/export/network/about)에
           따라 EqualsToVis 컨버터로 해당 패널만 Visible.

     호출 인터페이스는 기존과 동일: new SettingsDialog(vm).ShowDialog()
     ════════════════════════════════════════════════════════════════════ -->
<UserControl x:Class="SPILab.NowMoment.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="맑은 고딕"
             Background="{DynamicResource Theme.BgMain}">

    <UserControl.Resources>
        <!-- ─── 1. 섹션 제목 (큰 글씨, Accent) ─── -->
        <Style x:Key="SettingsPanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- ─── 2. 섹션 부제목 (작은 회색) ─── -->
        <Style x:Key="SettingsPanelHint" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Foreground"   Value="{DynamicResource Theme.FgSecondary}"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ─── 3. 필드 라벨 ─── -->
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="Margin"     Value="0,14,0,6"/>
        </Style>

        <!-- ─── 4. 힌트 (필드 아래 작은 글씨) ─── -->
        <Style x:Key="SettingsHintInline" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgMuted}"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

        <!-- ─── 5. 입력 TextBox ─── -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource Theme.Cyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 6. 멀티라인 TextBox ─── -->
        <Style x:Key="SettingsTextBoxMulti" TargetType="TextBox" BasedOn="{StaticResource SettingsTextBox}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping"  Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MinHeight"     Value="100"/>
            <Setter Property="FontFamily"    Value="Consolas"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding"       Value="8,6"/>
        </Style>

        <!-- ─── 7. ComboBoxItem (드롭다운 항목) ─── -->
        <Style x:Key="SettingsComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"  Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 8. ComboBox ─── -->
        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="26"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource Theme.FgSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush"
                                                        Value="{DynamicResource Theme.Cyan}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,30,0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="{DynamicResource Theme.FgPrimary}"
                                              TextElement.FontSize="13"
                                              IsHitTestVisible="False"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                                <Border Background="{DynamicResource Theme.BgCard}"
                                        BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="320">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 9. PasswordBox 스타일 ─── -->
        <Style x:Key="SettingsPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource Theme.FgPrimary}"/>
        </Style>

        <!-- ─── 10. CheckBox ─── -->
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,8,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ─── 11. 찾아보기 버튼 (Browse) ─── -->
        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="MinHeight"       Value="32"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 12. 푸터 [취소] / [기본값 복원] ─── -->
        <Style x:Key="FooterSecondaryBtn" TargetType="Button" BasedOn="{StaticResource BrowseButton}">
            <Setter Property="MinWidth"   Value="100"/>
            <Setter Property="Padding"    Value="18,8"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- ─── 13. 푸터 [✓ 저장] ─── -->
        <Style x:Key="FooterPrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Theme.FgOnAccent}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Theme.Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="22,8"/>
            <Setter Property="MinWidth"        Value="100"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.AccentDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 14. 좌측 카테고리 ListBoxItem ─── -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="Padding"     Value="14,10"/>
            <Setter Property="Margin"      Value="0,2"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Theme.Accent}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Theme.FgOnAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 15. 카드 Border (좌측/우측 패널 공용) ─── -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource Theme.BgCard}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource Theme.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="20"/>
        </Style>

        <!-- ─── 16. 정보 패널 행 (라벨 + 값) ─── -->
        <Style x:Key="AboutKey" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.FgSecondary}"/>
            <Setter Property="Margin"     Value="0,0,16,8"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="AboutVal" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Foreground"   Value="{DynamicResource Theme.FgPrimary}"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <!-- ═══ 본문 ═══ -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>     <!-- 좌측 카테고리 -->
            <ColumnDefinition Width="20"/>      <!-- 여백 -->
            <ColumnDefinition Width="*"/>       <!-- 우측 패널 -->
        </Grid.ColumnDefinitions>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <!-- 좌측: 카테고리 카드 (ListBox)                            -->
        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="4,0,0,12">
                    <Run Text="⚙ " Foreground="{DynamicResource Theme.Accent}" FontSize="14"/>
                    <Run Text="설정 카테고리" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource Theme.Accent}"/>
                </TextBlock>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource CategoryItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}"  FontSize="15"
                                           Width="26" TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" FontSize="14"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <!-- 우측: 패널 카드 (8개 패널이 SelectedCategoryKey 로 토글)  -->
        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>  <!-- 푸터 -->
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="28,24,28,8">
                    <Grid>
                        <!-- ▣ 일반 (general) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=general}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="🎨 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="일반 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="앱 외관과 시작 동작을 설정합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="테마"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="280" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding Theme}"/>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Text="저장 시 즉시 적용됩니다. System 은 OS 설정을 따릅니다."/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="언어"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="280" HorizontalAlignment="Left"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding Language}"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="시작 화면"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="280" HorizontalAlignment="Left"
                                      ItemsSource="{Binding StartScreens}"
                                      SelectedItem="{Binding StartScreen}"/>
                        </StackPanel>

                        <!-- ▣ Python (python) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=python}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="🐍 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="Python 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="Python 인터프리터와 가상환경 경로를 지정합니다. KG 빌더 실행에 사용됩니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource SettingsLabel}">
                                <Run Text="Python 실행 파일 경로 "/>
                                <Run Text="*" Foreground="{DynamicResource Theme.Error}"/>
                            </TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding PythonPath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="📁 찾아보기"
                                        Style="{StaticResource BrowseButton}"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowsePythonCommand}"/>
                            </Grid>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Foreground="{DynamicResource Theme.Success}"
                                       Text="{Binding PythonDetectStatus}"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="가상환경 경로 (선택)"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding VenvPath}"/>
                                <Button Grid.Column="1" Content="📁 찾아보기"
                                        Style="{StaticResource BrowseButton}"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseVenvCommand}"/>
                            </Grid>

                            <TextBlock Style="{StaticResource SettingsLabel}"
                                       Text="환경변수 (PYTHONPATH 등)"/>
                            <TextBox Style="{StaticResource SettingsTextBoxMulti}"
                                     Text="{Binding EnvVars}"
                                     Height="110"/>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Text="줄 단위 KEY=VALUE 형식으로 입력하세요."/>

                            <TextBlock Style="{StaticResource SettingsLabel}"
                                       Text="KG 빌더 타임아웃 (초)"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding KgTimeoutSec}"
                                     Width="160" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- ▣ KG 빌더 (kg) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=kg}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="🕸 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="KG 빌더 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="build_kg_*.py 스크립트 위치와 산출물 출력 폴더를 지정합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="스크립트 폴더"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding KgScriptDir}"/>
                                <Button Grid.Column="1" Content="📁 찾아보기"
                                        Style="{StaticResource BrowseButton}"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseKgScriptCommand}"/>
                            </Grid>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="출력 폴더"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding KgOutputDir}"/>
                                <Button Grid.Column="1" Content="📁 찾아보기"
                                        Style="{StaticResource BrowseButton}"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseKgOutputCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- ▣ DB (db) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=db}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="💾 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="DB 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="SQLite WAL 체크포인트와 자동 백업 주기를 설정합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="자동 백업 주기"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="280" HorizontalAlignment="Left"
                                      ItemsSource="{Binding AutoBackupOptions}"
                                      SelectedItem="{Binding AutoBackup}"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="WAL 체크포인트 주기 (분)"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding WalCheckpointMin}"
                                     Width="160" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Text="최소 5분. 작은 값은 디스크 IO 가 증가합니다."/>
                        </StackPanel>

                        <!-- ▣ 보안 (security) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=security}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="🔒 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="보안 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="DB 암호화와 백업 비밀번호를 관리합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <CheckBox Style="{StaticResource SettingsCheckBox}"
                                      Content="DB 암호화 사용 (재시작 후 적용)"
                                      IsChecked="{Binding DbEncryption}"/>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Text="SQLCipher 가 활성화된 경우에만 효과가 있습니다."/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="백업 비밀번호"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding BackupPassword}"
                                     Width="320" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource SettingsHintInline}"
                                       Text="DB 백업 시 zip 보호 비밀번호로 사용됩니다."/>
                        </StackPanel>

                        <!-- ▣ 내보내기 (export) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=export}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="📤 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="내보내기 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="자산 그리드 내보내기 시 기본값을 설정합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="기본 형식"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="200" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ExportFormatOptions}"
                                      SelectedItem="{Binding ExportFormat}"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="인코딩"/>
                            <ComboBox Style="{StaticResource SettingsComboBox}"
                                      Width="200" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ExportEncodingOptions}"
                                      SelectedItem="{Binding ExportEncoding}"/>

                            <CheckBox Style="{StaticResource SettingsCheckBox}"
                                      Content="헤더 행 포함"
                                      IsChecked="{Binding ExportIncludeHeader}"
                                      Margin="0,18,0,0"/>
                        </StackPanel>

                        <!-- ▣ 네트워크 (network) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=network}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="🌐 " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="네트워크 설정"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="외부 HTTP/HTTPS 요청에 사용되는 프록시 및 타임아웃을 설정합니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,12"/>

                            <CheckBox Style="{StaticResource SettingsCheckBox}"
                                      Content="프록시 사용"
                                      IsChecked="{Binding ProxyEnabled}"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="프록시 호스트"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding ProxyHost}"
                                     IsEnabled="{Binding ProxyEnabled}"
                                     Width="360" HorizontalAlignment="Left"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="프록시 포트"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding ProxyPort}"
                                     IsEnabled="{Binding ProxyEnabled}"
                                     Width="160" HorizontalAlignment="Left"/>

                            <TextBlock Style="{StaticResource SettingsLabel}" Text="네트워크 타임아웃 (초)"/>
                            <TextBox Style="{StaticResource SettingsTextBox}"
                                     Text="{Binding NetworkTimeoutSec}"
                                     Width="160" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- ▣ 정보 (about) -->
                        <StackPanel Visibility="{Binding SelectedCategoryKey,
                                    Converter={StaticResource EqualsToVis}, ConverterParameter=about}">
                            <TextBlock Style="{StaticResource SettingsPanelTitle}">
                                <Run Text="ℹ " Foreground="{DynamicResource Theme.Accent}"/>
                                <Run Text="정보"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource SettingsPanelHint}"
                                       Text="이 응용프로그램에 대한 버전 및 저작권 정보입니다."/>
                            <Separator Background="{DynamicResource Theme.Border}"
                                       Height="1" Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource AboutKey}" Text="제품"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource AboutVal}" Text="{Binding AppName}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource AboutKey}" Text="버전"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource AboutVal}" Text="{Binding AppVersion}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource AboutKey}" Text="제조사"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource AboutVal}" Text="{Binding AppCompany}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource AboutKey}" Text="저작권"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource AboutVal}" Text="{Binding AppCopyright}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource AboutKey}" Text="라이선스"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource AboutVal}" Text="{Binding AppLicense}"/>
                            </Grid>

                            <Border BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,16,0,0">
                                <TextBlock Style="{StaticResource SettingsHintInline}"
                                           Text="{Binding AppDescription}"
                                           FontSize="12"
                                           Foreground="{DynamicResource Theme.FgSecondary}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- ─── 푸터 ─── -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Theme.BgGridRowOdd}"
                        BorderBrush="{DynamicResource Theme.Border}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,8,8"
                        Padding="22,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="기본값 복원"
                                Style="{StaticResource FooterSecondaryBtn}"
                                Margin="0,0,8,0"
                                Command="{Binding RestoreDefaultsCommand}"/>
                        <Button Content="취소"
                                Style="{StaticResource FooterSecondaryBtn}"
                                Margin="0,0,8,0"
                                Command="{Binding CancelCommand}"/>
                        <Button Content="✓ 저장"
                                Style="{StaticResource FooterPrimaryBtn}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
